#!/bin/bash
# kill-brain - Stop intelligence engines on specific ports
# @param PORT: Port to clear (default: 8080)

set -e

PORT="${PORT:-8080}"
PID=$(lsof -ti :$PORT 2>/dev/null || true)

if [[ -n "$PID" ]]; then
    echo "🛑 Stopping intelligence engine on port $PORT (PID: $PID)..."
    kill "$PID"
    echo "✅ Port $PORT cleared."
else
    echo "⚠️  No process found on port $PORT."
fi
