#!/usr/bin/env zsh
# zsh/ui-board
# A persistent, visual, scalable, AND CLICKABLE "Board" surface.

# 1. READ SESSION STATE
source "$HOME/.config/zsh/parallax/core/projection-shell.zsh"
TARGET_PANE=$(cat "$PX_TARGET_FILE")
ACTIONS_ROOT=$(cat "$PX_STATE_DIR/.px_actions_root")

# 2. LOAD BUTTON DATA FROM REGISTRY
REGISTRY_FILE="$PX_REGISTRY_DIR/board.json"
if [[ -f "$REGISTRY_FILE" ]]; then
  # Parse JSON into Label|Key|Path|Color format
  BUTTON_DATA=(${(f)"$(jq -r '.[] | .label + "|" + .key + "|" + .path + "|" + .color' "$REGISTRY_FILE")"})
else
  # Fallback
  BUTTON_DATA=("EXIT BOARD|q|EXIT|red")
fi

# COLOR MAP
typeset -A COLORS
COLORS=(
  blue    "%K{blue}%F{white}"
  green   "%K{green}%F{white}"
  yellow  "%K{yellow}%F{black}"
  cyan    "%K{cyan}%F{white}"
  red     "%K{red}%F{white}"
)
RESET="%f%k"

# 3. MOUSE & GRID CONFIG
# Buttons are drawn in a 2-column grid.
# Row height = 4 (including spacing)
# Col width = 24 (including spacing)
# Start Y = 1, Start X = 3
COL1_X_MIN=3 COL1_X_MAX=20
COL2_X_MIN=27 COL2_X_MAX=44

# 4. UTILS
tmux set-option -q -p mouse on
print -n "\e[?1000h"
cleanup() { print -n "\e[?1000l"; exit 0; }
trap cleanup EXIT INT TERM

draw_board() {
  clear
  print -P "%K{black}%F{blue}  ━━━━━━━ CONTROL PLANE BOARD ━━━━━━━  %f%k"
  print ""

  local i=1
  local row_y=1
  while [[ $i -le ${#BUTTON_DATA} ]]; do
    # Column 1
    IFS='|' read label1 key1 path1 color1 <<< "${BUTTON_DATA[$i]}"
    # Column 2
    IFS='|' read label2 key2 path2 color2 <<< "${BUTTON_DATA[$((i+1))]}"

    # Row Lines
    local c1=$COLORS[$color1]
    local c2=$COLORS[$color2]
    
    # Check if col2 exists
    if [[ -n "$label1" ]]; then
        print -n "  ┏━━━━━━━━━━━━━━━━━━┓"
        [[ -n "$label2" ]] && print "    ┏━━━━━━━━━━━━━━━━━━┓" || print ""
        
        print -n "  ┃ ${c1}  [$key1] ${(r:12:)label1} ${RESET} ┃"
        [[ -n "$label2" ]] && print "    ┃ ${c2}  [$key2] ${(r:12:)label2} ${RESET} ┃" || print ""
        
        print -n "  ┗━━━━━━━━━━━━━━━━━━┛"
        [[ -n "$label2" ]] && print "    ┗━━━━━━━━━━━━━━━━━━┛" || print ""
        print ""
    fi
    ((i+=2))
  done
  
  print -P "  %F{white}Root: %F{blue}${ACTIONS_ROOT}%f"
  print -P "  %F{black}Last Click: [x=${LAST_X:-0}, y=${LAST_Y:-0}]  CLICK or press keys%f"
}

trigger_action() {
  local key_or_path="$1"
  if [[ "$key_or_path" == "EXIT" ]]; then exit 0; fi
  
  # Resolve path if it was a index/key
  for item in "${BUTTON_DATA[@]}"; do
    IFS='|' read l k p c <<< "$item"
    if [[ "$k" == "$key_or_path" ]]; then
       "$HOME/bin/dispatch" "$TARGET_PANE" "$ACTIONS_ROOT/$p"
       return
    fi
  done
}

# 5. INTERACTION LOOP
while true; do
  draw_board
  read -k 1 char
  
  if [[ "$char" == $'\e' ]]; then
    read -k 1 char2
    if [[ "$char2" == "[" ]]; then
        read -k 1 char3
        if [[ "$char3" == "M" ]]; then
            read -k 1 b_raw; read -k 1 x_raw; read -k 1 y_raw
            LAST_X=$(( #x_raw - 32 ))
            LAST_Y=$(( #y_raw - 32 ))
            
            # SCALABLE HIT-TESTING
            # Row index based on Y (integer math)
            # Buttons are at y=1, y=5, y=9... (Start at 1, step 4)
            # We map (y-1)/4 to get the row index
            local row=$(( (LAST_Y - 1) / 4 ))
            local col=0
            if (( LAST_X >= COL1_X_MIN && LAST_X <= COL1_X_MAX )); then col=1; fi
            if (( LAST_X >= COL2_X_MIN && LAST_X <= COL2_X_MAX )); then col=2; fi

            if [[ $col -gt 0 ]]; then
               # Calculate index in BUTTON_DATA array
               local idx=$(( row * 2 + col ))
               if [[ $idx -le ${#BUTTON_DATA} ]]; then
                 IFS='|' read l k p c <<< "${BUTTON_DATA[$idx]}"
                 trigger_action "$k"
               fi
            fi
            sleep 0.1
            continue
        fi
    fi
  else
    trigger_action "$char"
  fi
done
