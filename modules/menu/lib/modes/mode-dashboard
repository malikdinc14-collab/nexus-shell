#!/usr/bin/env zsh
# zsh/modes/mode-dashboard
# The Live Pulse of Parallax. 
# Displays Context Bucket, HUD status, and Recent Activity.

source "$HOME/.config/zsh/parallax/core/projection-shell.zsh"
CONTEXT_FILE="$PX_STATE_DIR/context.json"
HUD_FILE="$PX_STATE_DIR/.hud_msg"
HISTORY_FILE="$PX_STATE_DIR/history.log"

# UI Helpers
BOLD="%B"
DIM="%F{black}"
BLUE="%F{blue}"
GREEN="%F{green}"
YELLOW="%F{yellow}"
RESET="%b%f%k"

draw_dashboard() {
  clear
  print -P "${BOLD}${BLUE}  ━━━ PARALLAX OPTICAL DASHBOARD (v3) ━━━${RESET}"
  print ""

  # 1. LIVE CONTEXT (Shared Memory)
  print -P "${BOLD}  [ SHARED MEMORY ]${RESET}"
  if [[ -f "$CONTEXT_FILE" ]]; then
    jq -r 'to_entries | .[] | "  \(.key): \(.value)"' "$CONTEXT_FILE" | while read -r line; do
      print -P "  ${BLUE}•${RESET} ${line}"
    done
  else
    print -P "  ${DIM}No context initialized.${RESET}"
  fi
  print ""

  # 2. SYSTEM HEALTH (HUD)
  print -P "${BOLD}  [ SYSTEM HEALTH ]${RESET}"
  if [[ -f "$HUD_FILE" ]]; then
      local hud_msg=$(cat "$HUD_FILE")
      print -P "  ${GREEN}✚${RESET} HUD: ${hud_msg:-"Stable"}"
  else
      print -P "  ${YELLOW}⚠${RESET} HUD: Offline"
  fi
  print ""

  # 3. RECENT ACTIVITY (Activity Stream)
  print -P "${BOLD}  [ ACTIVITY STREAM ]${RESET}"
  if [[ -f "$HISTORY_FILE" ]]; then
    # Show last 5 commands/events
    tail -n 5 "$HISTORY_FILE" | awk -F'|' '{print "  " $3 " | " $4}' | while read -r line; do
       # Split and colorize
       type="${line%% |*}"
       msg="${line#*| }"
       icon="•"
       [[ "$type" == "cmd" ]] && icon=">"
       [[ "$type" == "chat" ]] && icon="?"
       print -P "  ${YELLOW}${icon}${RESET} ${msg:0:40}..."
    done
  else
    print -P "  ${DIM}No activity recorded.${RESET}"
  fi

  print ""
  print -P "${DIM}  (Toggle Dashboard: Ctrl-D | Refreshing every 2s... Hit Ctrl-C to exit)${RESET}"
}

# Main Loop
while true; do
  draw_dashboard
  sleep 2
done
