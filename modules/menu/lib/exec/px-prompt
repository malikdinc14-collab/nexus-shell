#!/usr/bin/env zsh
# bin/px-prompt
# Interactive prompt for Parameterized Actions

COLOR_KEY="\033[1;33m"
COLOR_RST="\033[0m"

VAR_NAME="$1"
DESCRIPTION="$2"
DEFAULT_VAL="$3"

# Format label: "Description (default)" or just "Description"
LABEL="$DESCRIPTION"
if [[ -n "$DEFAULT_VAL" ]]; then
    LABEL="$DESCRIPTION (default: $DEFAULT_VAL)"
fi

# Multi-line padding for clarity
echo "" >&2
echo -e " ${COLOR_KEY}┌── Parameter Input${COLOR_RST}" >&2
echo -e " ${COLOR_KEY}│${COLOR_RST}  ${LABEL}" >&2
echo -n -e " ${COLOR_KEY}└──>${COLOR_RST} " >&2

read INPUT_VAL < /dev/tty

# Fallback to default
FINAL_VAL="${INPUT_VAL:-$DEFAULT_VAL}"

# We output the export command so the caller can eval it
echo "export $VAR_NAME='$FINAL_VAL'"
