#!/usr/bin/env python3
import os
import json
import sys
from pathlib import Path

def main():
    session_path = Path.home() / ".parallax" / "session.json"
    if not session_path.exists():
        return

    try:
        with open(session_path) as f:
            session = json.load(f)
        
        # Mapping Parallax session fields to standard AI Env Vars
        env_map = {
            "llm_key": "OPENAI_API_KEY", # Standard AI Environment Variable
            "llm_endpoint": "OPENAI_API_BASE",
            "llm_provider": "PX_PROVIDER",
            "agent_id": "PX_AGENT_ID",
            "project_path": "PX_PROJECT_PATH"
        }

        for p_key, e_key in env_map.items():
            val = session.get(p_key)
            if val:
                # Output as export commands for shell sourcing
                print(f"export {e_key}='{val}'")
        
        # Special case for Ollama
        if session.get("llm_provider") == "ollama":
            print(f"export OLLAMA_HOST='{session.get('llm_endpoint', 'http://localhost:11434')}'")

    except: pass

if __name__ == "__main__":
    main()
