#!/usr/bin/env zsh
# bin/px-spy
# The Signal Observer (Standardized Protocol)

AUDIT_LOG="$HOME/.config/parallax/audit.log"
mkdir -p "$(dirname "$AUDIT_LOG")"

EVENT="${1:-PULSE}"
META="${2:-}"
TIMESTAMP=$(date "+%Y-%m-%d %H:%M:%S.%N" | cut -c1-23)
CUR_PID=$$
PAR_PID=$PPID
CUR_SHLVL=$SHLVL
PROC_NAME=$(basename "${3:-$0}")

# PROTOCOL: [TIMESTAMP] [EVENT] PID:X PPID:Y SHLVL:Z PROC:Name | MESSAGE
printf "[%s] [%-10s] PID:%s PPID:%s SHLVL:%s PROC:%s | %s\n" \
    "$TIMESTAMP" "$EVENT" "$CUR_PID" "$PAR_PID" "$CUR_SHLVL" "$PROC_NAME" "$META" >> "$AUDIT_LOG"
sync

