#!/usr/bin/env bash
# modules/menu/bin/nxs-action-dispatch
# The sovereign dispatcher for menu actions. 
# Handles Project -> Profile -> Global cascading lookups for verbs.

VERB=$1      # e.g., edit, run, context, favorite
ITEM_TYPE=$2 # e.g., NOTE, ACTION, TOOL, GAP_TASK
PAYLOAD=$3   # e.g., /path/to/file or command string

NEXUS_HOME="${NEXUS_HOME:-$(cd "$(dirname "$0")/../../.." && pwd)}"
PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"
NEXUS_EDITOR="${NEXUS_EDITOR:-nvim}"
LOG_FILE="/tmp/nexus_menu.log"
export NXS_STRICT_LOCAL=true

# Resolve Python Binary
[[ -x "$NEXUS_HOME/.venv/bin/python3" ]] && Python_BIN="$NEXUS_HOME/.venv/bin/python3" \
|| Python_BIN="${Python_BIN:-python3}"

# Helper for logging
log() { echo "[$(date +%T)] [Dispatch] $*" >> "$LOG_FILE"; }

log "Verb: $VERB | Type: $ITEM_TYPE | Payload: $PAYLOAD"

# 0. Intelligent Routing Kernel
if [[ "$ITEM_TYPE" == "NOTE" || "$ITEM_TYPE" == "ACTION" || -f "$PAYLOAD" ]]; then
    # Classify the payload extension
    REAL_TYPE=$("$Python_BIN" "$NEXUS_HOME/core/engine/api/classifier.py" "$PAYLOAD")
    log "Classifier Result: $REAL_TYPE for $PAYLOAD"
    
    # If the classifier wants a renderer but we were told to 'edit', reroute if not forced
    if [[ "$REAL_TYPE" == "renderer" && "$VERB" == "edit" ]]; then
        log "Rerouting from edit to renderer"
        # We can still allow editing if the user explicitly wants to edit a .md
        # but for now, let's stick to the design: default to editor for .md was requested later.
        # Wait, I set .md to 'editor' in classifier.py already.
        # So only truly 'renderable' things (images, mermaid) will hit this.
    fi
fi

# 1. Resolve Action from Registry
# Cascade: Project -> Profile -> Global
REGISTRY_FILES=(
    "${PROJECT_ROOT}/.nexus/config/actions.yaml"
    "${NEXUS_HOME}/config/profiles/${NEXUS_PROFILE}/actions.yaml"
    "${NEXUS_HOME}/config/actions.yaml"
)

get_action() {
    local verb=$1
    local type=$2
    for f in "${REGISTRY_FILES[@]}"; do
        if [[ -f "$f" ]]; then
            # Using python for clean YAML extraction
            local cmd=$($Python_BIN - "$f" "$type" "$verb" <<'PYEOF' 2>> "$LOG_FILE"
import sys, yaml
f_path, itype, iverb = sys.argv[1], sys.argv[2], sys.argv[3]
try:
    with open(f_path) as f:
        data = yaml.safe_load(f) or {}
    print(data.get(itype, {}).get(iverb, ""))
except Exception as e: sys.stderr.write(f"Error: {e}\n")
PYEOF
            )
            if [[ -n "$cmd" ]]; then
                echo "$cmd"
                return
            fi
        fi
    done
}

get_global_action() {
    local key=$1
    for f in "${REGISTRY_FILES[@]}"; do
        if [[ -f "$f" ]]; then
            local cmd=$($Python_BIN - "$f" "$key" <<'PYEOF' 2>> "$LOG_FILE"
import sys, yaml
f_path, key = sys.argv[1], sys.argv[2]
try:
    with open(f_path) as f:
        data = yaml.safe_load(f) or {}
    print(data.get("actions", {}).get(key, ""))
except Exception as e: sys.stderr.write(f"Error: {e}\n")
PYEOF
            )
            if [[ -n "$cmd" ]]; then
                echo "$cmd"
                return
            fi
        fi
    done
}

# Resolve Stack-Aware Binary
STACK_BIN="$NEXUS_KERNEL/stack/stack"

# Helper: Check if an identity is already in the local stack
check_stack() {
    local identity="$1"
    # Always use "local" - resolves to current focused pane at call time
    "$STACK_BIN" list "local" | jq -e ".tabs | to_entries | .[] | select(.value.name == \"$identity\") | .key" > /dev/null
}

# Helper: Get index of identity in local stack
get_stack_idx() {
    local identity="$1"
    # Always use "local" - resolves to current focused pane at call time
    "$STACK_BIN" list "local" | jq -r ".tabs | to_entries | .[] | select(.value.name == \"$identity\") | .key"
}

# 2. Handle Verbs
case "$VERB" in
    edit)
        # 0. Intelligent Routing Check
        if [[ "$REAL_TYPE" == "renderer" ]]; then
            log "Intelligent Routing: Rerouting $PAYLOAD to Local Stack (Renderer)"
            # Push to the LOCAL stack (In-Place)
            "$NEXUS_KERNEL/stack/stack" push "local" "$NEXUS_UI/view/view '$PAYLOAD'" "View: $(basename "$PAYLOAD")"
            exit 0
        fi

        # 1. Resolve Identity for Editor
        IDENTITY="editor"
        INTENT="${NXS_INTENT:-swap}"

        # SMART RESOLVE: If an editor is already in the stack, we switch to it
        if check_stack "$IDENTITY" && [[ "$INTENT" == "swap" || "$NXS_CALLER" == "menu" ]]; then
            IDX=$(get_stack_idx "$IDENTITY")
            log "SmartResolve: Switching to existing tab '$IDENTITY' at index $IDX"
            
            # If it's a file, we still want to open it in that editor
            if [[ -S "$NVIM_PIPE" && -f "$PAYLOAD" ]]; then
                 log "Sending remote command to existing editor: $PAYLOAD"
                 nvim --server "$NVIM_PIPE" --remote-send ":tabedit $PAYLOAD<CR>" 2>/dev/null
            fi
            
            "$STACK_BIN" switch "local" "$IDX"
            exit 0
        fi

        # 2. Editor Routing (Check for remote nvim server if not switched)
        if [[ -S "$NVIM_PIPE" ]]; then
            log "Remote nvim detected. Sending tabedit..."
            if [[ -f "$PAYLOAD" ]]; then
                nvim --server "$NVIM_PIPE" --remote-send ":tabedit $PAYLOAD<CR>" 2>> "$LOG_FILE"
                
                # Identify if editor is in another pane and focus it
                EDITOR_PANE=$(tmux list-panes -a -F "#{pane_id} #{@nexus_role}" | grep "editor" | head -n1 | awk '{print $1}')
                if [[ -n "$EDITOR_PANE" ]]; then
                    tmux select-pane -t "$EDITOR_PANE"
                    exit 0
                fi
            fi
        fi
        # 3. Fallback: Push to Stack
        CMD=$(get_action "edit" "$ITEM_TYPE")
        if [[ -n "$CMD" ]]; then
            eval "${CMD//\$PAYLOAD/$PAYLOAD}" 2>> "$LOG_FILE"
        else
            log "Pushing fresh editor instance to local stack"
            "$NEXUS_KERNEL/stack/stack" push "local" "$NEXUS_EDITOR '$PAYLOAD'" "$IDENTITY"
        fi
        ;;
    favorite)
        log "Favoriting $ITEM_TYPE: $PAYLOAD"
        # ... (existing favorite logic)
        exit 0
        ;;
    run)
        if [[ "$ITEM_TYPE" == "STACK_TAB" ]]; then
            ROLE="${PAYLOAD%%|*}"
            INDEX="${PAYLOAD##*|}"
            log "Switching Stack Tab: Role=$ROLE Index=$INDEX"
            "$STACK_BIN" switch "$ROLE" "$INDEX"
            exit 0
        fi
        
        # Determine Execution Intent
        # ... (rest of existing run logic)
        # ---
        PLAN_JSON=$($Python_BIN "$NEXUS_HOME/core/engine/api/intent_resolver.py" "$VERB" "$ITEM_TYPE" "$PAYLOAD" "$INTENT" "$NXS_CALLER" 2>> "$LOG_FILE")
        
        if [[ -z "$PLAN_JSON" ]]; then
            log "Kernel Error: Empty execution plan returned."
            exit 1
        fi

        STRATEGY=$(echo "$PLAN_JSON" | jq -r '.strategy')
        TARGET_ROLE=$(echo "$PLAN_JSON" | jq -r '.role')
        CMD=$(echo "$PLAN_JSON" | jq -r '.cmd')
        IDENTITY=$(echo "$PLAN_JSON" | jq -r '.name // empty')
        
        log "Kernel Execution: Strategy=$STRATEGY | Role=$TARGET_ROLE | Identity=$IDENTITY"

        case "$STRATEGY" in
            stack_switch)
                IDX=$(echo "$PLAN_JSON" | jq -r '.index')
                "$STACK_BIN" switch "local" "$IDX"
                ;;
            stack_replace)
                "$STACK_BIN" replace "$TARGET_ROLE" "$CMD" "$IDENTITY"
                ;;
            stack_push)
                "$STACK_BIN" push "$TARGET_ROLE" "$CMD" "$IDENTITY"
                ;;
            exec_local)
                eval "$CMD" 2>> "$LOG_FILE"
                ;;
            remote_control)
                TARGET=$(echo "$PLAN_JSON" | jq -r '.target')
                "$NEXUS_KERNEL/bin/control" "$TARGET" "$CMD"
                ;;
            *)
                log "Strategy mismatch: $STRATEGY. Falling back to default push."
                "$STACK_BIN" push "$TARGET_ROLE" "$CMD" "$IDENTITY"
                ;;
        esac
        exit 0
        ;;
    context)
        if [[ "$ITEM_TYPE" == "SHELF_ITEM" ]]; then
            log "Recalling stowed pane: $PAYLOAD"
            "${NEXUS_KERNEL}/exec/shelf.sh" recall "$PAYLOAD"
            exit 0
        fi

        log "Opening context menu for $ITEM_TYPE"
        # Spawns a sub-menu of available actions for this type
        # Extract context list from YAML
        ACTIONS_JSON=$($Python_BIN - "${REGISTRY_FILES[2]}" "$ITEM_TYPE" <<'PYEOF' 2>> "$LOG_FILE"
import sys, yaml, json
f_path, itype = sys.argv[1], sys.argv[2]
try:
    with open(f_path) as f:
        data = yaml.safe_load(f) or {}
    print(json.dumps(data.get(itype, {}).get("context", [])))
except Exception as e:
    sys.stderr.write(f"YAML Error: {e}\n")
    print("[]")
PYEOF
        )
        
        SELECTED=$(echo "$ACTIONS_JSON" | jq -r '.[] | .label' 2>> "$LOG_FILE" | fzf --ansi --header="Context Actions")
        if [[ -n "$SELECTED" ]]; then
            log "Selected context action: $SELECTED"
            CMD=$(echo "$ACTIONS_JSON" | jq -r ".[] | select(.label == \"$SELECTED\") | .cmd" 2>> "$LOG_FILE")
            eval "${CMD//\$PAYLOAD/$PAYLOAD}" 2>> "$LOG_FILE"
        fi
        ;;
    favorite)
        log "Favoriting $ITEM_TYPE: $PAYLOAD"
        FAV_DIR="$HOME/.nexus/favorites"
        mkdir -p "$FAV_DIR"
        
        # Determine specific favorite file based on type (lower-case)
        F_FILE="$FAV_DIR/${ITEM_TYPE,,}s.json"
        
        # Use python for robust JSON array manipulation
        $Python_BIN - "$F_FILE" "$PAYLOAD" <<'PYEOF'
import sys, json, os
f_path, payload = sys.argv[1], sys.argv[2]
data = []
if os.path.exists(f_path):
    try:
        with open(f_path, "r") as f:
            data = json.load(f)
    except: pass

if payload in data:
    data.remove(payload)
    print(f"Removed from favorites: {payload}")
else:
    data.append(payload)
    print(f"Added to favorites: {payload}")

with open(f_path, "w") as f:
    json.dump(data, f, indent=2)
PYEOF
        exit 0
        ;;
    *)
        echo "[Nexus] Unknown verb: $VERB"
        sleep 1
        ;;
esac
