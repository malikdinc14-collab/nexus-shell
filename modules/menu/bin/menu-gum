#!/usr/bin/env bash
# modules/menu/bin/menu-gum
# Ultra-lightweight, snappy menu for Nexus Shell.
# Powered by Charm's Gum (Go-based).

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MENU_ENGINE="${BIN_DIR}/../lib/core/menu_engine.py"
DISPATCH_BIN="${BIN_DIR}/action-dispatch"

# Standardize environment
export PATH="/opt/homebrew/bin:/usr/local/bin:/Users/compute/bin:$PATH"
export NEXUS_HOME="${NEXUS_HOME:-$(cd "${BIN_DIR}/../../.." && pwd)}"
export PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"

# Resolve Python Binary
[[ -x "$NEXUS_HOME/.venv/bin/python3" ]] && Python_BIN="$NEXUS_HOME/.venv/bin/python3" \
|| Python_BIN="${Python_BIN:-python3}"

CONTEXT="${1:-home}"
[[ "$CONTEXT" == "--context" ]] && CONTEXT="$2"

# 1. Fetch items from engine (JSON lines)
ITEMS_JSON=$("$Python_BIN" "$MENU_ENGINE" --context "$CONTEXT")

# 2. Extract Labels for Gum
LABELS=$(echo "$ITEMS_JSON" | "$Python_BIN" -c "import sys, json; [print(json.loads(line)['label']) for line in sys.stdin if line.strip()]")

# 3. Render with Gum Filter
SELECTED_LABEL=$(echo "$LABELS" | gum filter --placeholder="Nexus Pulse: $CONTEXT..." --indicator="→" --match.foreground="#00FFFF")

[[ -z "$SELECTED_LABEL" ]] && exit 0

# 4. Resolve the full JSON for the selected label
SELECTED_JSON=$(echo "$ITEMS_JSON" | "$Python_BIN" -c "import sys, json; label='$SELECTED_LABEL'; [print(json.dumps(json.loads(line))) for line in sys.stdin if json.loads(line).get('label') == label]")

# 5. Parse and Dispatch
TYPE=$("$Python_BIN" -c "import sys, json; print(json.loads(sys.stdin.read())['type'])" <<< "$SELECTED_JSON")
PAYLOAD=$("$Python_BIN" -c "import sys, json; print(json.loads(sys.stdin.read())['payload'])" <<< "$SELECTED_JSON")

if [[ "$TYPE" == "FOLDER" || "$TYPE" == "PLANE" ]]; then
    # Drill down recursively
    "$0" --context "$PAYLOAD"
else
    # Dispatch action
    export NXS_CALLER="menu"
    "$DISPATCH_BIN" "run" "$TYPE" "$PAYLOAD"
fi
