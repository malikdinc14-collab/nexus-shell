#!/usr/bin/env zsh
# bin/px-vault <action> [args...]
# Secure secret management for Parallax using MacOS Keychain.

SERVICE_NAME="parallax"
ACCOUNT_NAME="user-secrets"

case "$1" in
  set)
    # args: <key> [value]
    local key="$2"
    local val="$3"
    if [[ -z "$key" ]]; then
      echo "Usage: px-vault set <key> [value]"
      exit 1
    fi
    
    if [[ "$val" == "-" || -z "$val" ]]; then
      # Read from stdin (Hardened)
      security add-generic-password -U -a "$ACCOUNT_NAME" -s "$SERVICE_NAME" -l "$key" -w -
    else
      # Pass via argument (Legacy/Convenience)
      security add-generic-password -U -a "$ACCOUNT_NAME" -s "$SERVICE_NAME" -l "$key" -w "$val"
    fi
    echo "Saved secret '$key' to Keychain."
    ;;

  get)
    # args: <key>
    local key="$2"
    if [[ -z "$key" ]]; then
      echo "Usage: px-vault get <key>"
      exit 1
    fi
    # Use -w to output only the password content
    security find-generic-password -a "$ACCOUNT_NAME" -s "$SERVICE_NAME" -l "$key" -w 2>/dev/null
    ;;

  list)
    # Lists the labels of the generic passwords for this service
    security find-generic-password -a "$ACCOUNT_NAME" -s "$SERVICE_NAME" -g 2>&1 | grep "0x00000007 <blob>=" | sed 's/.*"\(.*\)".*/\1/'
    ;;

  delete)
    # args: <key>
    local key="$2"
    security delete-generic-password -a "$ACCOUNT_NAME" -s "$SERVICE_NAME" -l "$key"
    echo "Deleted secret '$key' from Keychain."
    ;;

  *)
    echo "Usage: px-vault {set|get|list|delete} [args...]"
    exit 1
    ;;
esac
