#!/usr/bin/env python3
import sys
import os
from pathlib import Path

# Bridge to lib.core.session
# This allows bin/parallax to continue calling `px-engine` 
# while the logic lives in a proper Python module.

# Add project root to sys.path
BIN_DIR = Path(__file__).parent.resolve()
PROJECT_ROOT = BIN_DIR.parent
sys.path.insert(0, str(PROJECT_ROOT))

# Run the session module
try:
    from lib.core import session
    session.main()
except ImportError as e:
    print(f"CRITICAL ERROR: Could not load Parallax Core Session: {e}", file=sys.stderr)
    sys.exit(1)
