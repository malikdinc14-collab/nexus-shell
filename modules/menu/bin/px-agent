#!/usr/bin/env zsh
# bin/px-agent
# Modular Agent Bridge

if [[ -z "$1" ]]; then
    echo "Usage: px-agent chat [command]"
    exit 1
fi

case "$1" in
    chat)
        shift
        # Load Parallax Session Context
        eval $(px-env-load)
        # Log invocation
        px-spy START "Agent Session: $@"
        # Execute the agent command
        eval "$@"
        px-spy EXIT "Agent Session Closed"
        ;;
    *)
        echo "Error: Unknown agent command $1"
        exit 1
        ;;
esac
