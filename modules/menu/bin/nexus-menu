#!/usr/bin/env zsh
# bin/nexus-menu
# The "Dumb Dashboard" Interface for Nexus
# Renders the FZF menu and outputs the selected payload for Nexus to route.

# Find the real directory (resolve symlinks)
BIN_DIR="${0:A:h}"
PROJECT_ROOT="${BIN_DIR:h}"

# The core FZF UI Loop
CURRENT_CTX="${1:-home}"

while true; do
    # Render items via the YAML engine, pipe to FZF
    selection=$( "${BIN_DIR}/px-engine" --context "$CURRENT_CTX" | fzf \
        --ansi --layout=reverse --border \
        --prompt="[$CURRENT_CTX] > " \
        --header="Nexus Menu" \
        --bind "esc:abort" )
    fzf_exit=$?

    # User pressed Escape or Ctrl-C
    if [[ $fzf_exit -ne 0 ]]; then
        # If we're not at home, go back to home
        if [[ "$CURRENT_CTX" != "home" ]]; then
            CURRENT_CTX="home"
            continue
        fi
        break
    fi

    # Parse the tab-delimited selection: LABEL<TAB>TYPE<TAB>PAYLOAD
    e_type=$(echo "$selection" | awk -F'\t' '{print $2}' | xargs)
    payload=$(echo "$selection" | awk -F'\t' '{print $3}' | xargs)

    case "$e_type" in
        PLANE)
            # Navigate into a sub-menu
            CURRENT_CTX="$payload"
            continue
            ;;
        FOLDER)
            # Same as PLANE for navigation
            CURRENT_CTX="$payload"
            continue
            ;;
        SEPARATOR|DISABLED|NONE)
            # Non-interactive items, ignore
            continue
            ;;
        *)
            # Executable payload (ACTION, PLACE, NOTE, etc.)
            # Output for the router and exit
            echo "${e_type}|${payload}"
            break
            ;;
    esac
done
