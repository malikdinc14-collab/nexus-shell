#!/usr/bin/env zsh
# modules/menu/bin/nexus-menu
# The Nexus Dashboard — Textual-powered Sovereign Menu (NXP).

BIN_DIR="${0:A:h}"
NXM_BIN="${BIN_DIR}/nxm.py"

# Standardize environment
export NEXUS_HOME="${NEXUS_HOME:-$(cd "${BIN_DIR}/../../.." && pwd)}"
export PROJECT_ROOT="${PROJECT_ROOT:-$(pwd)}"

# Resolve Python Binary
[[ -x "$NEXUS_HOME/.venv/bin/python3" ]] && Python_BIN="$NEXUS_HOME/.venv/bin/python3" \
|| Python_BIN="${Python_BIN:-python3}"

# Launch NXM
if [[ -f "$NXM_BIN" ]]; then
    "$Python_BIN" "$NXM_BIN" "$@"
else
    echo "CRITICAL: Nexus Menu Binary (nxm.py) not found at $NXM_BIN"
    exit 1
fi
