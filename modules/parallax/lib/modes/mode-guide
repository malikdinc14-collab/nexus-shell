#!/usr/bin/env zsh
# zsh/modes/mode-guide
# A self-contained interactive tutorial for Parallax (Source-View-Intent Model).

# 1. READ SESSION STATE
if [[ -z "$PX_ZSH_ROOT" ]]; then
    source "$HOME/.config/zsh/parallax/core/projection-shell.zsh"
fi
TARGET_PANE=$(cat "$PX_TARGET_FILE")

# Define the Narrative Journey
CHAPTERS=(
  "[alt-1] 1. The Protocol (Source-View-Intent)|SHOW_TEXT:intro"
  "[alt-2] 2. The Source (The Origin)|SHOW_TEXT:source"
  "[alt-3] 3. The View (The Lens)|SHOW_TEXT:view"
  "[alt-4] 4. The Intent (The Signal)|SHOW_TEXT:intent"
  "[alt-5] 5. The Body (Your Execution Plane)|SHOW_TEXT:body"
  "[alt-6] 6. Genesis (Smart Discovery)|SHOW_TEXT:genesis"
  "[alt-7] 7. Context (The Brain)|SHOW_TEXT:context"
  "---"
  "BACK (Return to Portal)|BACK"
)

# Text Content
show_text() {
  local active_name=$($HOME/bin/px-context get active_agent_name)
  local actions_root=$(cat "$PX_STATE_DIR/.px_actions_root" 2>/dev/null || echo "~/.actions")
  local current_selector=$($HOME/bin/px-context get primary_ui_selector || echo "fzf")
  
  clear
  case "$1" in
    intro)
      print -P "%K{blue}%F{white}  CHAPTER 1: THE PROTOCOL  %f%k"
      echo""
      echo "Old terminals are %F{red}Monolithic%f (Logic + UI + Execution stuck together)."
      echo "Parallax is %F{green}Modular%f. It splits every interaction into 3 phases:"
      echo ""
      echo "1. %F{cyan}SOURCE%f (The Origin): A command that outputs raw data lists."
      echo "   Example: 'px-source actions' -> Lists your scripts."
      echo ""
      echo "2. %F{magenta}VIEW%f (The Lens): A filter that pipes Source data into UI."
      echo "   Example: '| px-ui-composer' -> Draws the searchable menu."
      echo ""
      echo "3. %F{yellow}INTENT%f (The Signal): The user's choice."
      echo "   Example: 'EXECUTE:sys/update' -> The signal sent to the body."
      echo ""
      echo "This is the %F{blue}Source-View-Intent%f architecture."
      ;;
    source)
      print -P "%K{blue}%F{white}  CHAPTER 2: THE SOURCE  %f%k"
      echo ""
      echo "The %F{cyan}Source%f is the single source of truth for any list."
      echo "It follows the format: 'Label|Signal:Payload'"
      echo ""
      echo "Try running %F{cyan}px-source actions%f in your mind now to see the raw stream."
      echo ""
      echo "Available Sources:"
      echo "• actions, places, history, trace"
      echo "• recent, settings, lists"
      ;;
    view)
      print -P "%K{blue}%F{white}  CHAPTER 3: THE VIEW  %f%k"
      echo ""
      echo "The %F{magenta}View%f is how you see the world."
      echo "We support multiple view engines:"
      echo ""
      echo "• %F{white}Composer%f: The advanced UI with live headers and help text."
      echo "• %F{white}FZF%f: The standard fast fuzzy finder."
      echo "• %F{white}Term%f: A simple raw text selector."
      echo ""
      echo "You can switch Views instantly in Settings, or pipe manually:"
      echo "%F{white}px-source actions | px-ui-composer%f"
      ;;
    intent)
      print -P "%K{blue}%F{white}  CHAPTER 4: THE INTENT  %f%k"
      echo ""
      echo "The %F{yellow}Intent%f is the 'Verb' of your action."
      echo "Parallax supports 'Sticky Intents' - modes that change what ENTER does."
      echo ""
      echo "• %F{green}EXECUTE%f (Alt-1): Run immediately."
      echo "• %F{blue}STAGE%f (Alt-2): Paste into buffer (don't run)."
      echo "• %F{red}MODIFY%f (Alt-4): Open in Editor."
      echo ""
      echo "Your Intent travels over the `px-intent` bridge to the Body."
      ;;
    body)
      print -P "%K{blue}%F{white}  CHAPTER 5: THE BODY  %f%k"
      echo ""
      echo "The %F{green}Body%f is your Execution Plane."
      echo "It receives signals from the Mind via %F{white}bin/dispatch%f."
      echo ""
      echo "To link a terminal to your Mind:"
      echo "1. Run %F{white}px-link%f in the target terminal."
      echo "2. It registers its PID to ~/.config/parallax/links."
      echo "3. The Mind automatically discovers it."
      ;;
    genesis)
      print -P "%K{blue}%F{white}  CHAPTER 6: GENESIS  %f%k"
      echo ""
      echo "Parallax is context-aware via %F{cyan}Genesis%f."
      echo ""
      echo "Run %F{white}px-genesis%f in any folder."
      echo "It scans 'DNA files' (package.json, Makefile, etc) and:"
      echo "1. Mounts project-specific actions."
      echo "2. Sets environment variables."
      echo "3. Creates a Context Contract."
      ;;
    context)
      print -P "%K{blue}%F{white}  CHAPTER 7: CONTEXT  %f%k"
      echo ""
      echo "The %F{magenta}Context Brain%f stores your session state."
      echo ""
      echo "Current Agent: %F{green}${active_name:-None}%f"
      echo "Current UI:    %F{green}${current_selector}%f"
      echo "Actions Root:  %F{green}${actions_root}%f"
      echo ""
      echo "Modify this via 'Settings' or commands like:"
      echo "%F{white}px-context set active_agent_name CodingBot%f"
      ;;
  esac
  echo ""
  print -P "%F{black}%K{white} Press ANY KEY to return... %k%f"
  read -k 1
}

while true; do
  export PX_HUD_CONTEXT="Guide"
  selection=$(printf "%s\n" "${CHAPTERS[@]}" | px-ui-select "Parallax Guide > ")
  
  if [[ -z "$selection" || "$selection" == "BACK" ]]; then
     return 0
  fi

  label="${selection%%|*}"
  signal="${selection#*|}"

  if [[ "$signal" == SHOW_TEXT:* ]]; then
    show_text "${signal#SHOW_TEXT:}"
    continue
  fi

  if [[ "$signal" == "BACK" ]]; then
    return 0
  fi
done
