#!/usr/bin/env python3
import os
import sys
import subprocess
import json

# px-surface: Spatial Orchestration for Parallax
# Usage: 
#   px-surface apply [layout.yaml]
#   px-surface save [name]

def run_cmd(cmd):
    try:
        return subprocess.check_output(cmd, shell=True, text=True).strip()
    except:
        return ""

def parse_manual(content):
    # Minimal YAML parser for when 'yaml' module is missing
    panes = []
    current_pane = {}
    for line in content.splitlines():
        line = line.strip()
        if not line or line.startswith('#'): continue
        if line.startswith('- name:'):
            if current_pane: panes.append(current_pane)
            current_pane = {'name': line.split(':', 1)[1].strip()}
        elif line.startswith('command:'):
            current_pane['command'] = line.split(':', 1)[1].strip().strip('"')
        elif line.startswith('size:'):
            current_pane['size'] = line.split(':', 1)[1].strip()
    if current_pane: panes.append(current_pane)
    return panes

def dump_yaml(data):
    # Minimal YAML dumper
    lines = []
    lines.append(f"name: {data.get('name', 'Saved Surface')}")
    lines.append("panes:")
    for pane in data.get('panes', []):
        lines.append(f"  - name: \"{pane['name']}\"")
        lines.append(f"    command: \"{pane['command']}\"")
        lines.append(f"    size: \"{pane['size']}\"")
    return "\n".join(lines)

def capture_current():
    if not os.environ.get("TMUX"):
        print("Error: px-surface capture requires an active TMUX session.")
        return None

    # Get window name
    win_name = run_cmd("tmux display-message -p '#W'")
    
    # Get pane information: index, width, height, current command
    # Using format: index|width|height|cmd
    output = run_cmd("tmux list-panes -F '#{pane_index}|#{pane_width}|#{pane_height}|#{pane_current_command}'")
    
    panes = []
    lines = output.splitlines()
    total_w = int(run_cmd("tmux display-message -p '#{window_width}'"))
    total_h = int(run_cmd("tmux display-message -p '#{window_height}'"))

    for line in lines:
        idx, w, h, cmd = line.split('|')
        # Estimate size percentage (width for horizontal focus)
        perc = int(int(w) / total_w * 100)
        panes.append({
            "name": f"Pane {idx}",
            "command": "zsh", # Capturing the exact shell command is hard, default to shell
            "size": f"{perc}%"
        })
    
    return {"name": win_name, "panes": panes}

def save_surface(name):
    data = capture_current()
    if not data: return
    
    data['name'] = name
    # Determine target path
    # Check for project library first
    target_dir = os.path.join(os.getcwd(), ".parallax/library/surfaces")
    if not os.path.exists(target_dir):
        # Fallback to global library
        target_dir = os.path.expanduser("~/.parallax/library/surfaces")
    
    os.makedirs(target_dir, exist_ok=True)
    filename = name.lower().replace(" ", "_") + ".yaml"
    path = os.path.join(target_dir, filename)
    
    with open(path, 'w') as f:
        f.write(dump_yaml(data))
    
    print(f"Surface saved to: {path}")

def apply_surface(path):
    if not os.path.exists(path):
        print(f"Error: Surface not found at {path}")
        return

    content = open(path).read()
    try:
        import yaml
        data = yaml.safe_load(content)
        panes = data.get('panes', [])
        name = data.get('name', 'Parallax Surface')
    except:
        panes = parse_manual(content)
        name = "Parallax Surface"

    if not os.environ.get("TMUX"):
        print("Error: px-surface requires an active TMUX session.")
        return

    # Renaming current window is optional but helpful
    run_cmd(f'tmux rename-window "{name}"')

    # Start from a clean state (single pane)
    # Just split for now
    for i, pane in enumerate(panes):
        p_cmd = pane.get('command', 'zsh')
        p_size = pane.get('size', '')

        if i == 0:
            # First pane: use the current one
            run_cmd(f'tmux send-keys -t :. "{p_cmd}" C-m')
        else:
            # Subsequent panes: split
            split_flag = "-h" if i % 2 != 0 else "-v"
            size_arg = f"-p {p_size.rstrip('%')}" if p_size else ""
            run_cmd(f'tmux split-window {split_flag} {size_arg} "{p_cmd}"')

    # Balance panes if no specific sizes
    run_cmd("tmux select-layout tiled")

if __name__ == "__main__":
    if len(sys.argv) < 3:
        print("Usage: px-surface [apply|save] [path/name]")
        sys.exit(1)
    
    cmd = sys.argv[1]
    arg = sys.argv[2]
    
    if cmd == "apply":
        apply_surface(arg)
    elif cmd == "save":
        save_surface(arg)
    else:
        print(f"Unknown command: {cmd}")
        sys.exit(1)
