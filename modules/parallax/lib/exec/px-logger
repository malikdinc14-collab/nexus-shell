#!/usr/bin/env zsh
# bin/px-logger
# Utility to manage Parallax audit trails and mirroring.

COMMAND="$1"
HISTORY_FILE="$HOME/.config/parallax/history.log"

case "$COMMAND" in
    mirror)
        MSG="$2"
        local state_dir="${PX_STATE_DIR:-$HOME/.config/parallax}"
        if [[ -z "$PX_SESSION_ID" ]]; then
            if [[ -n "$TMUX" ]]; then
                PX_SESSION_ID=$(tmux display-message -p '#{pane_id}' | tr -d '%')
            else
                PX_SESSION_ID="$$"
            fi
        fi
        TARGET_FILE="$state_dir/.px_target_$PX_SESSION_ID"
        [[ ! -f "$TARGET_FILE" ]] && exit 0
        TARGET_PANE=$(cat "$TARGET_FILE")
        if [[ "$TARGET_PANE" =~ "^[0-9]+$" ]]; then
            MIRROR_FILE="$state_dir/.px_mirror_$TARGET_PANE"
            echo "$MSG" > "$MIRROR_FILE"
            kill -USR2 "$TARGET_PANE" 2>/dev/null
        fi
        ;;

    list-stream)
        STREAM_TYPE="${2:-cmd}"
        [[ ! -f "$HISTORY_FILE" ]] && exit 0
        grep "|${STREAM_TYPE}|" "$HISTORY_FILE"
        ;;

    clear-history)
        echo -n "" > "$HISTORY_FILE"
        ;;

    log)
        # Usage: px-logger log <STREAM> <LABEL> <PAYLOAD> [CHAIN_ID]
        STREAM="$2"
        LABEL="$3"
        PAYLOAD="$4"
        CHAIN="${5:-NONE}"
        SESSION="${PX_SESSION_ID:-$$}"
        TIMESTAMP=$(date "+%Y-%m-%d %H:%M:%S")
        echo "$TIMESTAMP|$SESSION|$STREAM|$LABEL|$PAYLOAD|$CHAIN" >> "$HISTORY_FILE"
        ;;

    *)
        echo "Usage: px-logger {mirror|list-stream|clear-history|log} [args]"
        exit 1
        ;;
esac
