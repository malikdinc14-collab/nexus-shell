#!/usr/bin/env zsh
# bin/px-preset
# Manages, resolves, and activates Parallax Presets.

# Resolve the project root, handling symlinks
SOURCE="${BASH_SOURCE[0]:-${(%):-%x}}"
while [ -L "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PROJ_DIR="$( cd -P "$( dirname "$SOURCE" )/.." >/dev/null 2>&1 && pwd )"

PRESETS_GLOBAL="$HOME/.config/parallax/presets"
PRESETS_REGISTRY="$PROJ_DIR/registry/presets"
LOCAL_PRESETS="./.parallax/presets"

# Dependency: jq
if ! command -v jq &>/dev/null; then
  echo "Error: 'jq' is required for px-preset."
  exit 1
fi

list_presets() {
  # Find all json files in local, global, and registry
  local files=(
    ${LOCAL_PRESETS}/*.json(N)
    ${PRESETS_GLOBAL}/*.json(N)
    ${PRESETS_REGISTRY}/*.json(N)
  )
  
  for f in "${files[@]}"; do
    local id=$(jq -r '.id' "$f")
    local name=$(jq -r '.name' "$f")
    echo "$id|$name|$f"
  done
}

resolve_active() {
  local target_index="${1:-0}"
  local files=(
    ${LOCAL_PRESETS}/*.json(N)
    ${PRESETS_GLOBAL}/*.json(N)
    ${PRESETS_REGISTRY}/*.json(N)
  )
  
  local -a matches
  matches=()

  for file in "${files[@]}"; do
    local score=0
    
    # Single jq pass to get all conditions
    local data
    data=$(jq -r '[.conditions.path_match, .conditions.has_file, .terminal_index, .priority // 100] | @tsv' "$file" 2>/dev/null)
    [[ -z "$data" ]] && continue

    local path_pattern=$(echo "$data" | cut -f1)
    local has_file=$(echo "$data" | cut -f2)
    local preset_index=$(echo "$data" | cut -f3)
    local priority=$(echo "$data" | cut -f4)

    # 1. Path Match
    if [[ -n "$path_pattern" && "$path_pattern" != "null" ]]; then
       if [[ "$PWD" == ${~path_pattern} ]]; then
         score=$((score + 100))
       else
         continue
       fi
    fi

    # 2. File Match
    if [[ -n "$has_file" && "$has_file" != "null" ]]; then
      if [[ -f "$has_file" ]]; then
        score=$((score + 50))
      else
        continue
      fi
    fi

    # 3. Index Match
    if [[ -n "$preset_index" && "$preset_index" != "null" && "$preset_index" != "0" ]]; then
       if [[ "$preset_index" == "$target_index" ]]; then
         score=$((score + 100)) # Increased weight for explicit terminal binding
       else
         continue
       fi
    fi

    # 4. Default Match
    if [[ $score -eq 0 ]] && [[ -z "$path_pattern" || "$path_pattern" == "null" ]] && [[ -z "$has_file" || "$has_file" == "null" ]]; then
       score=1
    fi

    if [[ $score -gt 0 ]]; then
      matches+=("$score|$priority|$file")
    fi
  done
  
  if [[ ${#matches} -gt 0 ]]; then
    # Sort by score (desc), then priority (asc)
    printf "%s\n" "${matches[@]}" | sort -t'|' -k1,1rn -k2,2n | head -1 | cut -d'|' -f3
  fi
}

create_preset() {
  echo "--- Parallax Preset Wizard ---"
  local id=""
  while [[ -z "$id" ]]; do
    read "id?Preset ID (e.g. project-x): "
  done

  local name=""
  read "name?Display Name (e.g. Project X HUD): "
  [[ -z "$name" ]] && name="$id"

  echo "\nConditions (leave blank to skip):"
  local path_match=""
  read "path_match?Path Pattern (e.g. */src/*): "
  [[ -z "$path_match" ]] && path_match="$PWD"

  local has_file=""
  read "has_file?Required File (e.g. package.json): "

  echo "\nBindings:"
  local ui="ui-term"
  read "ui?UI Surface [ui-term]: "
  [[ -z "$ui" ]] && ui="ui-term"

  local mode="mode-portal"
  read "mode?Initial Mode [mode-portal]: "
  [[ -z "$mode" ]] && mode="mode-portal"

  local priority=100
  read "priority?Priority [100]: "
  [[ -z "$priority" ]] && priority=100

  # Construct JSON
  local json=$(jq -n \
    --arg id "$id" \
    --arg name "$name" \
    --arg path "$path_match" \
    --arg file "$has_file" \
    --arg ui "$ui" \
    --arg mode "$mode" \
    --argjson prio "$priority" \
    '{id: $id, name: $name, conditions: {path_match: $path, has_file: $file}, bindings: {ui: $ui, mode: $mode}, priority: $prio}')

  local out_dir="$LOCAL_PRESETS"
  mkdir -p "$out_dir"
  echo "$json" > "$out_dir/$id.json"
  echo "\n✅ Preset created: $out_dir/$id.json"
}

get_field() {
  # Get a specific field from a preset file
  local file="$1"
  local field="$2"
  local default="$3"
  
  if [[ -f "$file" ]]; then
    local value=$(jq -r ".${field} // empty" "$file")
    if [[ -n "$value" ]]; then
      echo "$value"
    else
      echo "$default"
    fi
  else
    echo "$default"
  fi
}

case "$1" in
  list)
    list_presets
    ;;
  create)
    create_preset
    ;;
  resolve)
    resolve_active "$2"
    ;;
  cat)
    # Print the resolved preset json
    local file=$(resolve_active "$2")
    if [[ -n "$file" ]]; then
      cat "$file"
    fi
    ;;
  get)
    # Get a specific field: px-preset get <session> <field> [default]
  local file=$(resolve_active "$2")
  local field="$3"
  
  # Handle nested bindings (e.g. body.mode)
  if [[ "$field" == "body.mode" ]]; then
      get_field "$file" "bindings.body.mode" "$4"
  elif [[ "$field" == "mind.mode" ]]; then
      get_field "$file" "bindings.mind.mode" "$4"
  else
      get_field "$file" "$field" "$4"
  fi
  ;;
  *)
    echo "Usage: px-preset {list|create|resolve|cat|get}"
    exit 1
    ;;
esac
