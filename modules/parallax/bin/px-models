#!/usr/bin/env python3
import os
import sys
import json
from pathlib import Path

# Prioritize .models in current directory, then home
# Canonical Model Store
MODELS_ROOT = Path.home() / ".models"

def list_models(capability, fmt=None):
    if capability == "all" and fmt:
        all_models = []
        for cap in ["llm", "vision", "audio", "embeddings"]:
            all_models.extend(list_models(cap, fmt))
        return sorted(list(set(all_models)))

    target_dir = MODELS_ROOT / capability
    if fmt:
        target_dir = target_dir / fmt
    
    if not target_dir.exists():
        return []

    models = []
    
    # 1. MLX Logic: Look for config.json
    for p in target_dir.rglob("config.json"):
        models.append(str(p.parent.relative_to(target_dir)))
        
    # 2. GGUF Logic: Look for .gguf
    for p in target_dir.rglob("*.gguf"):
        # If it's in a dedicated folder under the target_dir, return the relative folder path
        rel = p.parent.relative_to(target_dir)
        if str(rel) != ".":
            models.append(str(rel))
        else:
            models.append(p.name)
            
    # Deduplicate and sort
    return sorted(list(set(models)))

def find_model_path(capability, fmt, name):
    # Try direct path
    p = MODELS_ROOT / capability / fmt / name
    if p.exists(): return p
    
    # If capability is 'all', search
    if capability == "all":
        for cap in ["llm", "vision", "audio", "embeddings"]:
            p = MODELS_ROOT / cap / fmt / name
            if p.exists(): return p
            
    return None

def main():
    if len(sys.argv) < 3:
        print("Usage: px-models <list|path> <capability|all> [format] [model_name]")
        print("Example: px-models list all mlx")
        sys.exit(1)

    cmd = sys.argv[1]
    capability = sys.argv[2]
    
    if cmd == "list" or cmd == "cat":
        fmt = sys.argv[3] if len(sys.argv) > 3 else None
        models = list_models(capability, fmt)
        for m in models:
            print(m)
    
    elif cmd == "path":
        if len(sys.argv) < 5:
            print("Error: path requires capability, format, and model_name")
            sys.exit(1)
        fmt = sys.argv[3]
        model_name = sys.argv[4]
        path = find_model_path(capability, fmt, model_name)
        if path:
            print(path)
        else:
            sys.exit(1)

if __name__ == "__main__":
    main()
