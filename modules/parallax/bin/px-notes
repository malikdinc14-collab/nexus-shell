#!/usr/bin/env zsh
# bin/px-notes
# Opens a scratchpad/notes file based on current Parallax scope.
# Located per-project in stealth mode or in ~/.parallax for global.

# Determine scope from session.json or fallback
SESSION_JSON="$HOME/.parallax/session.json"
NOTES_DIR=""
PROJECT_NAME=""

if [[ -f "$SESSION_JSON" ]]; then
    # Extract scope and project name from session
    SCOPE=$(python3 -c "import json; d=json.load(open('$SESSION_JSON')); print(d.get('scope', 'GLOBAL'))" 2>/dev/null)
    PROJECT_NAME=$(python3 -c "import json; d=json.load(open('$SESSION_JSON')); print(d.get('project_name', ''))" 2>/dev/null)
    PROJECT_PATH=$(python3 -c "import json; d=json.load(open('$SESSION_JSON')); print(d.get('project_path', ''))" 2>/dev/null)
else
    SCOPE="GLOBAL"
fi

case "$SCOPE" in
    PROJECT)
        # Local .parallax/notes/
        NOTES_DIR="${PROJECT_PATH}/.parallax/notes"
        ;;
    STEALTH)
        # Central storage for stealth projects
        if [[ -n "$PROJECT_NAME" ]]; then
            NOTES_DIR="$HOME/.parallax/stealth/${PROJECT_NAME}/notes"
        else
            NOTES_DIR="$HOME/.parallax/notes"
        fi
        ;;
    *)
        # Global fallback
        NOTES_DIR="$HOME/.parallax/notes"
        ;;
esac

# Ensure notes directory exists
mkdir -p "$NOTES_DIR"

# Open scratchpad in user's preferred editor
NOTES_FILE="$NOTES_DIR/scratch.md"

# Create with template if new
if [[ ! -f "$NOTES_FILE" ]]; then
    echo "# Parallax Notes - ${PROJECT_NAME:-Global}\n\n---\n" > "$NOTES_FILE"
fi

# Open in editor
${EDITOR:-nano} "$NOTES_FILE"
