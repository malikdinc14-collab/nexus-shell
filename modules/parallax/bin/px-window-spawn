#!/bin/bash
# px-window-spawn - Open a new terminal window/tab attached to a specific Nexus view
# Usage: px-window-spawn [window_index] [window_name]

VIEW_INDEX="${1:-0}"
VIEW_NAME="$2"
SESSION_ID=$(tmux display-message -p '#S' 2>/dev/null || echo "nexus_$(basename $(pwd))")
PROJECT_ROOT=$(pwd)

# Mode: tab (default) or window
SPAWN_MODE="${PX_WINDOW_MODE:-tab}"

# Construct the command to run in the new window
# We use the launcher in 'spawn' mode to attach to the same session with independent view
CMD="$NEXUS_HOME/core/boot/launcher.sh '$PROJECT_ROOT' spawn \; select-window -t $VIEW_INDEX"

if [[ "$OSTYPE" == "darwin"* ]]; then
    echo "🚀 Spawning new $SPAWN_MODE for view $VIEW_INDEX ($VIEW_NAME)..."
    
    if [[ "$SPAWN_MODE" == "window" ]]; then
        osascript <<EOF
        tell application "iTerm"
            create window with default profile
            tell current session of current window
                write text "$CMD"
            end tell
        end tell
EOF
    else
        osascript <<EOF
        tell application "iTerm"
            tell current window
                create tab with default profile
                tell current session
                    write text "$CMD"
                end tell
            end tell
        end tell
EOF
    fi
else
    echo "❌ Automatic window spawning is currently only supported on macOS with iTerm2."
    echo "💡 Manual command: tmux attach -t $SESSION_ID \; select-window -t $VIEW_INDEX"
fi
