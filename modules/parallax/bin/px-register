#!/usr/bin/env zsh
# bin/px-register
# Register a project for Stealth Mode (no .parallax/ folder needed)

set -e

REGISTRY_FILE="$HOME/.parallax/registry.json"
PROJECTS_DIR="$HOME/.parallax/projects"

# Usage
if [[ $# -lt 1 ]]; then
    echo "Usage: px-register <project_path> [project_name]"
    echo ""
    echo "Registers a project for Stealth Mode."
    echo "Creates config at ~/.parallax/projects/<name>/"
    echo ""
    echo "Examples:"
    echo "  px-register .                    # Register current directory"
    echo "  px-register /path/to/project     # Register specific path"
    echo "  px-register . my-client          # Register with custom name"
    exit 1
fi

# Resolve path
PROJECT_PATH="$(cd "$1" && pwd)"
PROJECT_NAME="${2:-$(basename "$PROJECT_PATH")}"
PROJECT_CONFIG_DIR="$PROJECTS_DIR/$PROJECT_NAME"

echo "📋 Registering project for Stealth Mode"
echo "   Path: $PROJECT_PATH"
echo "   Name: $PROJECT_NAME"
echo ""

# Create project config directory
mkdir -p "$PROJECT_CONFIG_DIR/library"

# Create default dashboard.json
if [[ ! -f "$PROJECT_CONFIG_DIR/dashboard.json" ]]; then
    cat > "$PROJECT_CONFIG_DIR/dashboard.json" << EOF
{
  "title": "$PROJECT_NAME",
  "settings": {},
  "sections": []
}
EOF
    echo "✅ Created dashboard.json"
fi

# Initialize registry if needed
if [[ ! -f "$REGISTRY_FILE" ]]; then
    echo "{}" > "$REGISTRY_FILE"
fi

# Add to registry using Python for safe JSON manipulation
python3 << EOF
import json
import os

registry_file = "$REGISTRY_FILE"
project_path = "$PROJECT_PATH"
project_name = "$PROJECT_NAME"
config_dir = "$PROJECT_CONFIG_DIR"

# Load existing registry
with open(registry_file, 'r') as f:
    registry = json.load(f)

# Add/update entry
registry[project_path] = {
    "dashboard": f"{config_dir}/dashboard.json",
    "library": f"{config_dir}/library/"
}

# Save registry
with open(registry_file, 'w') as f:
    json.dump(registry, f, indent=2)

print(f"✅ Added to registry")
EOF

echo ""
echo "🎉 Project registered!"
echo ""
echo "Config location: $PROJECT_CONFIG_DIR"
echo ""
echo "When you 'cd $PROJECT_PATH' and run 'parallax',"
echo "it will use STEALTH mode with your registered config."
