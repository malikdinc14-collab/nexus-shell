# Load navigation utilities (cdr)
[[ -f "${PX_LIB_DIR:-$HOME/.parallax}/bin/px-cdr" ]] && source "${PX_LIB_DIR:-$HOME/.parallax}/bin/px-cdr"

# Sync CWD to Dashboard (Automatic Header Update)
_px_sync_cwd() {
    local shell_id="${PX_STAGE_PID:-$$}"
    local state_dir="${PX_STATE_DIR:-$HOME/.parallax}"
    local state_file="$state_dir/px-cwd-${shell_id}.txt"
    local link_file="$state_dir/links/shell-$shell_id.link"
    local debug_log="$state_dir/px-link-debug.log"
    
    # 1. Update State File
    echo "$PWD" > "$state_file"
    
    # 2. Notify Dashboard (if linked)
    if [[ -f "$link_file" ]]; then
        local target_pid=$(cat "$link_file")
        local meta_file="$state_dir/px-session-${target_pid}.meta"
        local tmux_target=""

        # Strategy A: Use metadata to find explicit Tmux Session
        if [[ -f "$meta_file" ]]; then
            # format: NAME|PATH|PID|TMUX_SESSION
            local raw_meta=$(cat "$meta_file")
            local t_session=$(echo "$raw_meta" | cut -d'|' -f4)
            if [[ -n "$t_session" ]]; then
                tmux_target="${t_session}:0.1"
            fi
        fi

        # Strategy B: Fallback to current session if in same context
        if [[ -z "$tmux_target" && -n "$TMUX" ]]; then
            # Assume we are in the Stage pane (0.0) targeting Dashboard (0.1)
            tmux_target=":0.1"
        fi

        # Send Trigger
        if [[ -n "$tmux_target" ]]; then
             # Send Ctrl-R (Refresh Bind)
             if command -v tmux >/dev/null; then
                 tmux send-keys -t "$tmux_target" 'C-r' 2>/dev/null
             fi
        fi
    fi
}
autoload -Uz add-zsh-hook
add-zsh-hook chpwd _px_sync_cwd

# Run initial discovery and sync
_px_discover_and_link
_px_sync_cwd
