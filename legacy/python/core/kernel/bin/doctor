#!/usr/bin/env python3
# core/bin/doctor
import os
import sys
import subprocess
import shutil
from pathlib import Path

class NexusDoctor:
    def __init__(self):
        self.nexus_home = Path(os.environ.get("NEXUS_HOME", Path(__file__).resolve().parents[2]))
        self.results = []

    def check_binary(self, name, critical=True):
        path = shutil.which(name)
        status = "PASSED" if path else ("FAILED" if critical else "WARNING")
        self.results.append({
            "name": f"Binary: {name}",
            "status": status,
            "message": f"Found at {path}" if path else f"{name} not found in PATH"
        })
        return bool(path)

    def check_env(self, var):
        val = os.environ.get(var)
        status = "PASSED" if val else "WARNING"
        self.results.append({
            "name": f"Env: {var}",
            "status": status,
            "message": f"Value: {val}" if val else f"{var} is not set"
        })

    def check_dir(self, path, name):
        exists = Path(path).exists()
        status = "PASSED" if exists else "FAILED"
        self.results.append({
            "name": f"Directory: {name}",
            "status": status,
            "message": f"Exists at {path}" if exists else f"Missing at {path}"
        })

    def report(self):
        print("\n" + "="*60)
        print(" Nexus Shell - Health & Diagnostics (doctor) ")
        print("="*60 + "\n")
        
        all_passed = True
        for res in self.results:
            icon = "✅" if res["status"] == "PASSED" else ("❌" if res["status"] == "FAILED" else "⚠️")
            print(f"{icon} {res['name']:<25} | {res['status']:<8} | {res['message']}")
            if res["status"] == "FAILED":
                all_passed = False
        
        print("\n" + "="*60)
        if all_passed:
            print(" SYSTEM IS HEALTHY. READY FOR OPERATION. ")
        else:
            print(" SYSTEM HAS ISSUES. PLEASE RESOLVE FAILURES. ")
        print("="*60 + "\n")
        return all_passed

def main():
    doctor = NexusDoctor()
    
    # 1. Critical Binaries
    doctor.check_binary("tmux")
    doctor.check_binary("zsh")
    doctor.check_binary("python3")
    doctor.check_binary("jq")
    doctor.check_binary("fzf")
    
    # 2. Environment
    doctor.check_env("NEXUS_HOME")
    doctor.check_env("PROJECT_ROOT")
    doctor.check_env("NVIM_PIPE")
    
    # 3. Directories
    doctor.check_dir(doctor.nexus_home, "NEXUS_HOME")
    doctor.check_dir(doctor.nexus_home / "core", "Core Modules")
    doctor.check_dir(doctor.nexus_home / "modules", "Ext Modules")
    
    # 4. Optional Binaries
    doctor.check_binary("yazi", critical=False)
    doctor.check_binary("nvim", critical=False)

    passed = doctor.report()
    sys.exit(0 if passed else 1)

if __name__ == "__main__":
    main()
