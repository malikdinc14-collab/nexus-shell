{
    "name": "school",
    "description": "Tailored for AI-assisted research and learning. High-fidelity diagrams + context-aware agent.",
    "layout": {
        "type": "hsplit",
        "panes": [
            {
                "id": "discover",
                "size": 25,
                "command": "YAZI_CONFIG_HOME=\"$NEXUS_HOME/config/yazi\" $NEXUS_FILES '$PROJECT_ROOT'"
            },
            {
                "type": "vsplit",
                "panes": [
                    {
                        "id": "menu",
                        "size": 8,
                        "command": "$NEXUS_MENU_CMD"
                    },
                    {
                        "id": "theory",
                        "command": "$EDITOR_CMD"
                    },
                    {
                        "id": "vision",
                        "size": 30,
                        "command": "watch -n 1 '$NEXUS_HOME/modules/render/bin/view $PROJECT_ROOT/.nexus/vision/active.mmd'"
                    }
                ]
            },
            {
                "id": "tutor",
                "size": 40,
                "command": "$NEXUS_HOME/modules/agents/bin/nxs-agent-boot.sh"
            }
        ]
    }
}
