{
    "name": "vscodelike",
    "description": "A feature-rich layout mimicking modern IDEs with tree, editor, terminal, and AI chat.",
    "layout": {
        "type": "hsplit",
        "panes": [
            {
                "id": "files",
                "size": 30,
                "command": "YAZI_CONFIG_HOME=\"$NEXUS_HOME/config/yazi\" $NEXUS_FILES '$VIRTUAL_ROOT'"
            },
            {
                "type": "vsplit",
                "panes": [
                    {
                        "id": "menu",
                        "size": "8",
                        "command": "$NEXUS_HOME/modules/menu/bin/nexus-menu"
                    },
                    {
                        "id": "editor",
                        "command": "$EDITOR_CMD"
                    },
                    {
                        "id": "terminal",
                        "size": "10",
                        "command": "${SHELL:-/bin/bash} -i"
                    }
                ]
            },
            {
                "id": "chat",
                "size": 45,
                "command": "$NEXUS_CHAT"
            }
        ]
    }
}