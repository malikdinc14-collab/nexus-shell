{
    "name": "terminal",
    "description": "A terminal-heavy layout for deep shell work.",
    "layout": {
        "type": "vsplit",
        "panes": [
            {
                "id": "main",
                "command": "/bin/zsh -i"
            },
            {
                "id": "logs",
                "size": 30,
                "command": "tail -f /tmp/nexus_station.log"
            }
        ]
    }
}