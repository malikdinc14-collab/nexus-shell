#!/usr/bin/env zsh
# modules/menu/bin/nexus-menu
# The Nexus Dashboard — Textual-powered Sovereign Menu (NXP).

BIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]:-${(%):-%x}}")" && pwd)"
export PATH="/opt/homebrew/bin:/usr/local/bin:/Users/compute/bin:$PATH"
export NEXUS_HOME="${NEXUS_HOME:-$(cd "${BIN_DIR}/../../.." && pwd)}"
export MENU_ENGINE="${BIN_DIR}/../lib/core/menu_engine.py"
# Ensure TERM is set for proper TUI key handling (backspace, arrows)
export TERM="${TERM:-xterm-256color}"

# --- Axiom: Dependency Validation ---
if [[ ! -f "$MENU_ENGINE" ]]; then
    printf "\033[1;31m[CRITICAL] Menu Engine not found: %s\033[0m\n" "$MENU_ENGINE"
    exit 1
fi

# Resolve Python Binary
[[ -x "$NEXUS_HOME/.venv/bin/python3" ]] && Python_BIN="$NEXUS_HOME/.venv/bin/python3" \
|| Python_BIN="${Python_BIN:-python3}"

if ! command -v "$Python_BIN" &> /dev/null; then
    printf "\033[1;31m[CRITICAL] Python binary not found: %s\033[0m\n" "$Python_BIN"
    exit 1
fi

# Launch the engine in interactive mode
"$Python_BIN" "$MENU_ENGINE" "$@" --pick
