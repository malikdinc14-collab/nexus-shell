#!/bin/bash
# Nexus Shell Unified CLI Dispatcher
# V1: Professional Subcommand Routing

NEXUS_BIN="$(cd "$(dirname "$0")" && pwd)"
export NEXUS_HOME="$(cd "$NEXUS_BIN/.." && pwd)"
export NEXUS_CORE="$NEXUS_HOME/core"

show_help() {
    echo -e "\033[1;36m🌌 Nexus Shell CLI\033[0m"
    echo "Usage: nxs [command] [options]"
    echo ""
    echo "Commands:"
    echo "  boot [args]    Launch a new station (default)"
    echo "  stop           Kill all active Nexus stations and background daemons"
    echo "  list           List available layouts (compositions) and profiles"
    echo "  extension      Manage extensions (list, install, info)"
    echo "  profile        Manage user profile (show, edit, detect)"
    echo "  wizard         Run first-run setup wizard"
    echo "  doctor         Check system health and dependencies"
    echo "  status         Show active sessions and station info"
    echo "  version        Show version information"
    echo ""
    echo "Options:"
    echo "  -h, --help     Show this help message"
}

case "$1" in
    boot|"")
        shift
        [[ "$1" == "boot" ]] && shift
        exec "$NEXUS_CORE/boot/launcher.sh" "$@"
        ;;
    stop)
        shift
        exec "$NEXUS_CORE/boot/stop.sh" "$@"
        ;;
    list)
        shift
        exec "$NEXUS_CORE/boot/launcher.sh" --list
        ;;
    extension|ext)
        shift
        if [[ -f "$NEXUS_HOME/extensions/loader.sh" ]]; then
            case "${1:-list}" in
                list)
                    "$NEXUS_HOME/extensions/loader.sh" list
                    ;;
                install)
                    shift
                    "$NEXUS_HOME/extensions/loader.sh" install "$@"
                    ;;
                info)
                    shift
                    "$NEXUS_HOME/extensions/loader.sh" info "$@"
                    ;;
                uninstall)
                    shift
                    "$NEXUS_HOME/extensions/loader.sh" uninstall "$@"
                    ;;
                *)
                    echo "Usage: nxs extension {list|install|info|uninstall} [name]"
                    ;;
            esac
        else
            echo "[!] Extension system not found"
            exit 1
        fi
        ;;
    profile)
        shift
        PROFILE_FILE="$HOME/.nexus/profile.yaml"
        case "${1:-show}" in
            show)
                if [[ -f "$PROFILE_FILE" ]]; then
                    cat "$PROFILE_FILE"
                else
                    echo "[*] No profile found. Run 'nxs wizard' to create one."
                fi
                ;;
            edit)
                ${EDITOR:-nvim} "$PROFILE_FILE"
                ;;
            reset)
                rm -f "$PROFILE_FILE"
                rm -f "$HOME/.nexus/.first_run_complete"
                echo "[*] Profile reset. Run 'nxs wizard' to reconfigure."
                ;;
            detect)
                source "$NEXUS_HOME/core/lib/detector.sh"
                detect_as_json
                ;;
            roles)
                if [[ -f "$PROFILE_FILE" ]]; then
                    python3 -c "
import yaml
with open('$PROFILE_FILE') as f:
    data = yaml.safe_load(f)
for role, tool in data.get('roles', {}).items():
    print(f'{role}: {tool}')
"
                else
                    echo "[*] No profile found"
                fi
                ;;
            *)
                echo "Usage: nxs profile {show|edit|reset|detect|roles}"
                ;;
        esac
        ;;
    wizard)
        if [[ -f "$NEXUS_CORE/boot/first_run.sh" ]]; then
            NEXUS_SKIP_FIRST_RUN=1 source "$NEXUS_CORE/boot/first_run.sh" --force
        else
            echo "[!] Wizard not found"
            exit 1
        fi
        ;;
    doctor)
        shift
        if [[ -f "$NEXUS_CORE/boot/doctor.sh" ]]; then
            exec "$NEXUS_CORE/boot/doctor.sh" "$@"
        else
            echo "[!] Error: Doctor script not found at $NEXUS_CORE/boot/doctor.sh"
            exit 1
        fi
        ;;
    status)
        shift
        tmux list-sessions | grep "^nexus_" || echo "No active Nexus stations."
        ;;
    version)
        echo "Nexus Shell v2.1.0 (Sovereign Pro)"
        ;;
    -h|--help|help)
        show_help
        ;;
    *)
        # Fallback to boot if first arg looks like a project/flag
        exec "$NEXUS_CORE/boot/launcher.sh" "$@"
        ;;
esac
