#!/usr/bin/env python3
import curses
import sys
import os
import argparse
import subprocess
import tempfile
import time

# Parsing Arguments
parser = argparse.ArgumentParser(description="Parallax Modular Input Bar")
parser.add_argument("--sticky-headers", action="store_true", help="Keep headers associated with matching items")
parser.add_argument("--prompt", default="Parallax > ", help="Prompt string")
parser.add_argument("--footer", default="", help="Footer string")
parser.add_argument("--bind", action="append", help="Bind key to signal (e.g. 'tab:STAGE')")
parser.add_argument("--initial-query", default="", help="Initial text in prompt")
args = parser.parse_args()

def is_header(line):
    return line.startswith("###") or line.startswith("---")

def filter_items_sticky(items, query):
    if not query: return list(items)
    q_lower = query.lower()
    matched_indices = set()
    header_indices = [i for i, line in enumerate(items) if is_header(line)]
    for i, line in enumerate(items):
        if not is_header(line) and q_lower in line.lower():
            matched_indices.add(i)
    if args.sticky_headers:
        for m_idx in matched_indices:
            governing_header = -1
            for h in header_indices:
                if h < m_idx: governing_header = h
                else: break
            if governing_header != -1: matched_indices.add(governing_header)
    for i in header_indices:
        if q_lower in items[i].lower(): matched_indices.add(i)
    return [items[i] for i in sorted(list(matched_indices))]

def filter_items_flat(items, query):
    if not query: return list(items)
    q = query.lower()
    return [i for i in items if q in i.lower()]

class ComposerUI:
    def __init__(self, stdscr, items):
        self.stdscr = stdscr
        self.items = items
        self.query = args.initial_query
        self.filtered = list(items)
        self.selected_idx = 0
        self.show_list = True
        
        self.bindings = {}
        if args.bind:
            for b in args.bind:
                if ":" in b:
                    k, sig = b.split(":", 1)
                    self.bindings[k.lower()] = sig

        curses.start_color()
        curses.use_default_colors()
        curses.init_pair(1, -1, -1)
        curses.init_pair(2, curses.COLOR_BLUE, -1)
        curses.init_pair(3, curses.COLOR_CYAN, -1)
        curses.init_pair(4, curses.COLOR_BLACK, curses.COLOR_WHITE)
        curses.init_pair(5, curses.COLOR_BLACK, curses.COLOR_WHITE)
        
        self.refilter()
        self.ensure_valid_selection(1)

    def refilter(self):
        if args.sticky_headers:
            self.filtered = filter_items_sticky(self.items, self.query)
        else:
            self.filtered = filter_items_flat(self.items, self.query)
        if self.selected_idx >= len(self.filtered):
            self.selected_idx = max(0, len(self.filtered) - 1)

    def is_selectable(self, idx):
        if idx < 0 or idx >= len(self.filtered): return False
        return not is_header(self.filtered[idx])

    def ensure_valid_selection(self, direction):
        if not self.filtered: return
        attempts = 0
        while not self.is_selectable(self.selected_idx) and attempts < len(self.filtered):
            self.selected_idx += direction
            if self.selected_idx < 0: self.selected_idx, direction = 0, 1
            elif self.selected_idx >= len(self.filtered): self.selected_idx, direction = len(self.filtered)-1, -1
            attempts += 1

    def move_selection(self, delta):
        new_idx = self.selected_idx + delta
        while 0 <= new_idx < len(self.filtered):
            if self.is_selectable(new_idx):
                self.selected_idx = new_idx
                return
            new_idx += delta

    def render(self):
        self.stdscr.erase()
        max_y, max_x = self.stdscr.getmaxyx()
        prompt_y = max_y - 1
        footer_y = max_y - 2 if args.footer else -1
        list_bottom = footer_y if args.footer else prompt_y
        
        mode_suffix = " [FOCUS]" if not self.show_list else ""
        prompt_str = f"{args.prompt}{self.query}{mode_suffix}"
        
        if self.show_list:
            list_height = list_bottom
            start_idx = 0
            if len(self.filtered) > list_height and self.selected_idx >= list_height:
                start_idx = self.selected_idx - list_height + 1
            for i in range(list_height):
                idx = start_idx + i
                if idx >= len(self.filtered): break
                line = self.filtered[idx]
                style = curses.color_pair(2) | curses.A_BOLD if is_header(line) else (curses.color_pair(4) | curses.A_BOLD if idx == self.selected_idx else curses.color_pair(1))
                try: self.stdscr.addstr(i, 0, line[:max_x-1], style)
                except: pass

        if args.footer:
            try: self.stdscr.addstr(footer_y, 0, args.footer[:max_x-1], curses.color_pair(5))
            except: pass
        try:
            self.stdscr.addstr(prompt_y, 0, prompt_str, curses.color_pair(3) | curses.A_BOLD)
            self.stdscr.move(prompt_y, min(len(args.prompt) + len(self.query), max_x-1))
        except: pass
        self.stdscr.refresh()

    def jump_to_editor(self):
        curses.def_shell_mode()
        curses.endwin()
        try:
            with tempfile.NamedTemporaryFile(suffix=".txt", delete=False) as tmp:
                tmp.write(self.query.encode('utf-8'))
                tmp_path = tmp.name
            editor = os.environ.get("EDITOR", "vi")
            subprocess.call([editor, tmp_path])
            with open(tmp_path, "r") as f:
                self.query = f.read().strip()
            os.unlink(tmp_path)
        finally:
            self.stdscr.refresh()
            return True

    def loop(self):
        while True:
            self.render()
            key = self.stdscr.getch()
            if key == -1: continue
            
            key_label = None
            if key == 27:
                self.stdscr.nodelay(False)
                next_key = self.stdscr.getch()
                self.stdscr.nodelay(True)
                if next_key == ord('f'): 
                    self.show_list = not self.show_list
                    continue
                elif next_key == -1 or next_key == 27: return ("esc", "")
                else: key_label = f"alt-{chr(next_key).lower()}"
            elif key == curses.KEY_UP: self.move_selection(-1)
            elif key == curses.KEY_DOWN: self.move_selection(1)
            elif key == 9: key_label = "tab"
            elif key == curses.KEY_RIGHT: key_label = "right"
            elif key == 5: key_label = "ctrl-e"
            elif key in [10, 13, curses.KEY_ENTER]: key_label = "enter"
            elif key in [curses.KEY_BACKSPACE, 127]:
                if len(self.query) > 0:
                    self.query = self.query[:-1]
                    self.selected_idx = 0
                    self.refilter()
                    self.ensure_valid_selection(1)
            elif 32 <= key <= 126:
                self.query += chr(key)
                self.selected_idx = 0
                self.refilter()
                self.ensure_valid_selection(1)

            if key_label in self.bindings:
                sig = self.bindings[key_label]
                val = self.query
                if self.show_list and 0 <= self.selected_idx < len(self.filtered):
                    val = self.filtered[self.selected_idx]
                if sig == "EDIT":
                    if self.jump_to_editor():
                        return ("enter", self.query)
                return (sig, val)
            
            if key_label == "enter":
                val = self.query
                if self.show_list and 0 <= self.selected_idx < len(self.filtered):
                    val = self.filtered[self.selected_idx]
                return ("enter", val)

if __name__ == "__main__":
    input_items = []
    if not sys.stdin.isatty():
        input_items = sys.stdin.read().splitlines()
        try: sys.stdin = open('/dev/tty', 'r')
        except: pass
    try:
        res = curses.wrapper(lambda s: ComposerUI(s, input_items).loop())
        if res:
            print(res[0]); print(res[1])
            sys.exit(0)
    except KeyboardInterrupt: sys.exit(1)
    except Exception as e:
        sys.exit(1)
