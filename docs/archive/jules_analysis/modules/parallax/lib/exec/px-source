#!/usr/bin/env zsh
# bin/px-source <command> [args...]
# The Universal Data Provider for Parallax.
# Generates "Label|Payload" lists for the UI.

CMD_SOURCE="$1"
shift

# Paths for JSON lists (from px-list logic)
LISTS_GLOBAL="$HOME/.config/parallax/lists"

# Resolve the project root, handling symlinks
SOURCE="${BASH_SOURCE[0]:-${(%):-%x}}"
while [ -L "$SOURCE" ]; do
  DIR="$( cd -P "$( dirname "$SOURCE" )" >/dev/null 2>&1 && pwd )"
  SOURCE="$(readlink "$SOURCE")"
  [[ $SOURCE != /* ]] && SOURCE="$DIR/$SOURCE"
done
PROJECT_ROOT="$( cd -P "$( dirname "$SOURCE" )/../.." >/dev/null 2>&1 && pwd )"

LISTS_REGISTRY="$PROJECT_ROOT/registry/lists"
LISTS_LOCAL="./.parallax/lists"

case "$CMD_SOURCE" in
...
  history)
    local stream="${PX_STREAM:-chat}"
    px-logger list-stream "$stream" 2>/dev/null | tail -n 100 | cut -d'|' -f5 | tail -r | awk '!x[$0]++' | tail -r | while read h; do
      echo "$h|HISTORY:$h"
    done
    ;;

  trace)
    px-logger get-tree 2>/dev/null | while read line; do
       local id="${line%%|*}"
       local label="${line#*|}"
       echo "$label ($id)|PROJECT:reader|$id"
    done
    ;;

  recent)
    px-logger list-stream all 2>/dev/null | tail -n 100 | awk -F'|' '
...
    ' | tail -r
    ;;
...
    echo "--- WORKSPACES ---|SEPARATOR"
    "$0" lists
    echo "--- SYSTEM & HELP ---|SEPARATOR"
    echo "📚 System Guide|PLANE:guide"
    echo "⚙️  Settings & Presets|PLANE:settings"
    echo "🛠️  Diagnostic & Genesis|PLANE:diagnostic"
    echo "---|SEPARATOR"
    echo "Exit|PLANE:exit"
    ;;

  *)
    # Dynamic Plugin Resolution
    # Look for executable scripts in sources/
    local plugin_script="$PROJECT_ROOT/sources/$CMD_SOURCE"
    if [[ -x "$plugin_script" ]]; then
      "$plugin_script" "$@"
      exit $?
    fi

    echo "Usage: $0 {actions|places|prompts|history|trace|recent|settings|lists|list-items|menu}"
    echo "       or any script in sources/"
    exit 1
    ;;
esac
