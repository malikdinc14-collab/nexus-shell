#!/bin/bash
# bin/px-exec
# Handles internal plumbing for Parallax Actions to keep user shell clean.
# Usage: px-exec <session_id> <action_path>

SESSION_ID="$1"
ACTION_PATH="$2"
shift 2

if [[ -z "$SESSION_ID" || -z "$ACTION_PATH" ]]; then
    echo "Usage: px-exec <session_id> <action_path>"
    exit 1
fi

# 1. Source Environment
ENV_FILE="/tmp/px-env-${SESSION_ID}.sh"
if [[ -f "$ENV_FILE" ]]; then
    source "$ENV_FILE"
fi

# 2. Source Parameters
PARAMS_FILE="/tmp/px-collected-params-${SESSION_ID}.sh"
if [[ -f "$PARAMS_FILE" ]]; then
    source "$PARAMS_FILE"
fi

# 3. Log Intent
if command -v px-spy >/dev/null; then
    px-spy EXEC "Action: $ACTION_PATH"
fi

# 4. Execute Action (Clean)
# We use eval to handle any shell complexities in the path or arguments
eval "$ACTION_PATH"
