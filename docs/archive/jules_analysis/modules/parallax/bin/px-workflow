#!/bin/bash
# px-workflow: Manage RDT (Requirements, Design, Tasks) links and status

set -e

WORKFLOW_DIR="$(pwd)/docs/workflow"

case "$1" in
    list)
        ls -R "$WORKFLOW_DIR"
        ;;
    new)
        # Usage: px-workflow new req REQ-002 "New Feature"
        TYPE="$2"
        ID="$3"
        TITLE="$4"
        DIR="$WORKFLOW_DIR/${TYPE}s"
        [[ "$TYPE" == "design" ]] && DIR="$WORKFLOW_DIR/design"
        
        FILE="$DIR/$ID.md"
        mkdir -p "$DIR"
        
        cat > "$FILE" << EOF
# $ID: $TITLE

## Overview
$TITLE

## Status: Pending

## Interlinks
- 

EOF
        echo "✅ Created $FILE"
        ;;
    link)
        # Usage: px-workflow link REQ-001 DSN-001
        SRC="$2"
        DST="$3"
        SRC_FILE=$(find "$WORKFLOW_DIR" -name "$SRC.md")
        DST_FILE=$(find "$WORKFLOW_DIR" -name "$DST.md")
        
        if [[ -f "$SRC_FILE" && -f "$DST_FILE" ]]; then
            echo "- Linked to: [$DST](../$(basename $(dirname $DST_FILE))/$(basename $DST_FILE))" >> "$SRC_FILE"
            echo "- Linked from: [$SRC](../$(basename $(dirname $SRC_FILE))/$(basename $SRC_FILE))" >> "$DST_FILE"
            echo "✅ Linked $SRC and $DST"
        else
            echo "❌ Could not find $SRC or $DST"
            exit 1
        fi
        ;;
    status)
        # Usage: px-workflow status TSK-001 "completed"
        ID="$2"
        STATUS="$3"
        TSK_FILE=$(find "$WORKFLOW_DIR/tasks" -name "$ID.md")
        if [[ -f "$TSK_FILE" ]]; then
            sed -i '' "s/Status:.*/Status: $STATUS/" "$TSK_FILE"
            echo "✅ Updated $ID status to $STATUS"
        else
            echo "❌ Task $ID not found"
        fi
        ;;
    *)
        echo "Usage: px-workflow [list|link|status]"
        exit 1
        ;;
esac
