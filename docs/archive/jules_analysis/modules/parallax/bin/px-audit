#!/usr/bin/env zsh
# bin/px-audit
# Robust Signal Audit Visualizer (Field-Agnostic Mode)

AUDIT_LOG="$HOME/.config/parallax/audit.log"
echo ">>> PARALLAX SIGNAL AUDIT (Tailing $AUDIT_LOG)"
echo "--------------------------------------------------------------------------------"
mkdir -p "$(dirname "$AUDIT_LOG")"
echo -n "" > "$AUDIT_LOG"
touch "$AUDIT_LOG"

tail -f "$AUDIT_LOG" | awk '
/PID:/ {
    msg = $0
    split(msg, segments, "|")
    header = segments[1]
    body = segments[2]

    # Robust Field Extraction
    split(header, fields, " ")
    depth = 3
    proc = "unknown"
    for (i=1; i<=10; i++) {
        if (fields[i] ~ /^SHLVL:/) { split(fields[i], p, ":"); depth = p[2] }
        if (fields[i] ~ /^PROC:/)  { split(fields[i], p, ":"); proc = p[2] }
    }

    # Indentation Guard
    if (depth > 10) depth = 10
    indent = ""
    for (i=3; i<depth; i++) indent = indent "  "
    indent = indent "└─ "

    # Color Selection
    if (msg ~ /START/)  { color="\033[1;32m" }
    else if (msg ~ /EXIT/)   { color="\033[1;31m" }
    else if (msg ~ /INT/)    { color="\033[1;33m" }
    else if (msg ~ /NAV/)    { color="\033[1;35m" }
    else if (msg ~ /ENTITY/) { color="\033[1;36m" }
    else if (msg ~ /EXEC/)   { color="\033[1;97m" }
    else if (msg ~ /WARN/)   { color="\033[1;41m" }
    else { color="\033[0m" }
    
    printf "%s%s%-12s | %s\033[0m\n", color, indent, proc, body
}'
