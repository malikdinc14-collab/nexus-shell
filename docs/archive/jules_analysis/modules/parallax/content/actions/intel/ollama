#!/bin/bash
# Ollama - Local Model Manager
# @param ACTION: What to do [start, stop, list, pull, chat, status, import-gguf]
# @param MODEL: Model name or GGUF path $(if [[ "$ACTION" == "import-gguf" ]]; then px-models list all gguf; else ollama list 2>/dev/null | tail -n +2 | awk '{print $1}'; fi)

set -e

case "$ACTION" in
    start)
        if lsof -i :11434 > /dev/null 2>&1; then
            echo "⚠️  Ollama daemon already running (Port 11434)."
        else
            echo "🚀 Starting Ollama daemon..."
            nohup ollama serve > /tmp/px-ollama.log 2>&1 &
            sleep 2
            if lsof -i :11434 > /dev/null 2>&1; then
                echo "✅ Ollama daemon started."
            else
                echo "❌ Failed to start. Check /tmp/px-ollama.log"
            fi
        fi
        ;;
    stop)
        PID=$(lsof -ti :11434 2>/dev/null || true)
        if [[ -n "$PID" ]]; then
            echo "🛑 Stopping Ollama daemon (PID: $PID)..."
            kill "$PID"
            echo "✅ Ollama stopped."
        else
            echo "⚠️  Ollama is not running."
        fi
        ;;
    list)
        echo "📋 Local Models:"
        ollama list
        ;;
    pull)
        [[ -z "$MODEL" ]] && MODEL="llama3"
        echo "📥 Pulling model: $MODEL..."
        ollama pull "$MODEL"
        ;;
    chat)
        [[ -z "$MODEL" ]] && { echo "❌ MODEL is required."; exit 1; }
        echo "💬 Starting chat with $MODEL... (Ctrl+D to exit)"
        ollama run "$MODEL"
        ;;
    status)
        if lsof -i :11434 > /dev/null 2>&1; then
            echo "✅ Ollama daemon running on port 11434"
            echo ""
            ollama list
        else
            echo "⚠️  Ollama daemon not running."
        fi
        ;;
    import-gguf)
        [[ -z "$MODEL" ]] && { echo "❌ MODEL (GGUF path) is required."; exit 1; }
        
        # Try resolving in any capability folder
        GGUF_PATH=$(px-models path all gguf "$MODEL" 2>/dev/null || echo "$MODEL")
        
        # If the path is a directory, find the first .gguf inside it
        if [[ -d "$GGUF_PATH" ]]; then
            GGUF_FILE=$(find "$GGUF_PATH" -name "*.gguf" | head -n 1)
        else
            GGUF_FILE="$GGUF_PATH"
        fi
        
        [[ ! -f "$GGUF_FILE" ]] && { echo "❌ GGUF file not found at $GGUF_FILE"; exit 1; }
        
        IMPORT_NAME=$(basename "$MODEL" | sed 's/\.gguf//I')
        echo "📦 Importing $GGUF_FILE as Ollama model '$IMPORT_NAME'..."
        
        printf "FROM $GGUF_FILE" > /tmp/px-ollama-modelfile
        ollama create "$IMPORT_NAME" -f /tmp/px-ollama-modelfile
        rm /tmp/px-ollama-modelfile
        echo "✅ Model '$IMPORT_NAME' imported successfully."
        ;;
    *)
        echo "Usage: ACTION=[start|stop|list|pull|chat|status|import-gguf]"
        exit 1
        ;;
esac
