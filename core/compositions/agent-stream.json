{
    "name": "agent-stream",
    "description": "Agent-Stream: Neovim Follower and Structured Task Monitor.",
    "layout": {
        "type": "vsplit",
        "panes": [
            {
                "id": "editor",
                "size": 65,
                "title": "👁️ FOLLOWER (NVIM)",
                "command": "$EDITOR_CMD"
            },
            {
                "type": "hsplit",
                "size": 35,
                "panes": [
                    {
                        "id": "task_checklist",
                        "size": 40,
                        "title": "📋 MISSION STATUS",
                        "command": "watch -n 2 glow -s dark $PROJECT_ROOT/.gap/specs/tasks"
                    },
                    {
                        "id": "thought_stream",
                        "size": 60,
                        "title": "💭 AGENT STREAM",
                        "command": "$NEXUS_CORE/services/nxs-stream.sh"
                    }
                ]
            }
        ]
    }
}
