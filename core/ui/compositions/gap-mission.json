{
    "name": "gap-mission",
    "description": "Premium GAP Development Layout with Integrated Spec Manager",
    "layout": {
        "direction": "vertical",
        "panes": [
            {
                "direction": "horizontal",
                "panes": [
                    {
                        "command": "nvim",
                        "size": "65%"
                    },
                    {
                        "direction": "vertical",
                        "panes": [
                            {
                                "command": "gap-spec.sh",
                                "size": "40%"
                            },
                            {
                                "command": "pi-gap.sh",
                                "size": "60%"
                            }
                        ],
                        "size": "35%"
                    }
                ],
                "size": "80%"
            },
            {
                "command": "zsh",
                "size": "20%"
            }
        ]
    }
}
