{
    "name": "music-studio",
    "description": "Music production workstation: audio player, visualizer, and editor.",
    "layout": {
        "type": "hsplit",
        "panes": [
            {
                "id": "files",
                "size": 20,
                "command": "YAZI_CONFIG_HOME=\"$NEXUS_HOME/config/yazi\" $NEXUS_FILES '$PROJECT_ROOT'"
            },
            {
                "type": "vsplit",
                "panes": [
                    {
                        "id": "menu",
                        "size": 6,
                        "command": "$NEXUS_MENU_CMD"
                    },
                    {
                        "id": "editor",
                        "command": "$EDITOR_CMD"
                    },
                    {
                        "id": "visualizer",
                        "size": 10,
                        "command": "cava 2>/dev/null || echo 'Install: brew install cava'"
                    }
                ]
            },
            {
                "id": "player",
                "size": 40,
                "command": "spotify_player 2>/dev/null || ncspot 2>/dev/null || echo 'Install: brew install spotify-player'"
            }
        ]
    }
}