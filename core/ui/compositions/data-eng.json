{
    "name": "data-eng",
    "description": "Data engineering workstation: SQL, data exploration, and analysis.",
    "layout": {
        "type": "hsplit",
        "panes": [
            {
                "id": "files",
                "size": 20,
                "command": "YAZI_CONFIG_HOME=\"$NEXUS_HOME/config/yazi\" $NEXUS_FILES '$PROJECT_ROOT'"
            },
            {
                "type": "vsplit",
                "panes": [
                    {
                        "id": "menu",
                        "size": 6,
                        "command": "$PARALLAX_CMD"
                    },
                    {
                        "id": "editor",
                        "command": "$EDITOR_CMD"
                    },
                    {
                        "id": "terminal",
                        "size": 12,
                        "command": "/bin/zsh -i"
                    }
                ]
            },
            {
                "type": "vsplit",
                "size": 50,
                "panes": [
                    {
                        "id": "sql",
                        "size": 60,
                        "command": "harlequin 2>/dev/null || lazysql 2>/dev/null || echo 'Install: brew install harlequin'"
                    },
                    {
                        "id": "data",
                        "command": "vd 2>/dev/null || echo 'Install: pip install visidata'"
                    }
                ]
            }
        ]
    }
}