{
    "commands": [
        {
            "names": [
                "q",
                ":q"
            ],
            "action": "$NEXUS_BOOT/guard.sh exit_session",
            "description": "Quit Station",
            "category": "Exit"
        },
        {
            "names": [
                "qa",
                ":qa"
            ],
            "action": "$NEXUS_BOOT/guard.sh exit_session",
            "description": "Quit entire session (all windows)",
            "category": "Exit"
        },
        {
            "names": [
                "wq",
                ":wq"
            ],
            "action": "python3 $NEXUS_HOME/core/layout/save_layout.py 2>/dev/null; $NEXUS_BOOT/guard.sh exit_session",
            "description": "Save layout and quit station",
            "category": "Exit",
            "preflight": "save_all"
        },
        {
            "names": [
                "wqa",
                ":wqa"
            ],
            "action": "python3 $NEXUS_HOME/core/layout/save_layout.py --all 2>/dev/null; $NEXUS_BOOT/guard.sh exit_session",
            "description": "Save all layouts and quit entire session",
            "category": "Exit",
            "preflight": "save_all"
        },
        {
            "names": [
                "save",
                ":save"
            ],
            "action": "python3 $NEXUS_HOME/core/layout/save_layout.py",
            "description": "Save current layout to project configuration",
            "category": "System"
        },
        {
            "names": [
                "q!",
                ":q!"
            ],
            "action": "$NEXUS_BOOT/guard.sh force_session",
            "description": "Force quit station without saving",
            "category": "Exit"
        },
        {
            "names": [
                "qa!",
                ":qa!"
            ],
            "action": "$NEXUS_BOOT/guard.sh force_session",
            "description": "Force quit entire session without saving",
            "category": "Exit"
        },
        {
            "names": [
                "v",
