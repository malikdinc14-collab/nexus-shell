{
    "commands": [
        {
            "names": [
                "q",
                ":q"
            ],
            "action": "$NEXUS_BOOT/guard.sh exit",
            "description": "Quit Nexus",
            "category": "Exit"
        },
        {
            "names": [
                "wq",
                ":wq"
            ],
            "action": "$NEXUS_BOOT/guard.sh exit",
            "description": "Save all and quit",
            "category": "Exit",
            "preflight": "save_all"
        },
        {
            "names": [
                "q!",
                ":q!"
            ],
            "action": "$NEXUS_BOOT/guard.sh force",
            "description": "Force quit without saving",
            "category": "Exit"
        },
        {
            "names": [
                "v",
                ":v"
            ],
            "action": "$NEXUS_HOME/lib/swap.sh",
            "description": "Toggle Editor/Render mode",
            "category": "View"
        },
        {
            "names": [
                "g",
                ":g"
            ],
            "action": "$NEXUS_HOME/lib/tree_swap.sh",
            "description": "Toggle Tree/Git mode",
            "category": "View"
        },
        {
            "names": [
                "kill",
                ":kill"
            ],
            "action": "$NEXUS_CORE/api/kill_agent.sh",
            "description": "Terminate active agent loops",
            "category": "AI"
        },
        {
            "names": [
                "down",
                ":down"
            ],
            "action": "$NEXUS_CORE/api/unload_brains.sh",
            "description": "Unload all local models and backends",
            "category": "AI"
        },
        {
            "names": [
                "spawn",
                ":spawn"
            ],
            "action": "$NEXUS_BIN/px-window-spawn",
            "description": "Open a new terminal tab (spawn 2 for Monitor)",
            "category": "System",
            "args": true
        },
        {
            "names": [
                "n",
                ":n"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_TREE_PANE:-0} 2>/dev/null || tmux select-pane -t tree 2>/dev/null",
            "description": "Focus Navigator (Tree)",
            "category": "Navigation"
        },
        {
            "names": [
                "p",
                ":p",
                "px",
                "parallax",
                ":px",
                ":parallax"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_PARALLAX_PANE:-1} 2>/dev/null || tmux select-pane -t parallax 2>/dev/null",
            "description": "Focus Parallax Dashboard",
            "category": "Navigation"
        },
        {
            "names": [
                "e",
                ":e"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_EDITOR_PANE:-2} 2>/dev/null || tmux select-pane -t editor 2>/dev/null",
            "description": "Focus Editor",
            "category": "Navigation"
        },
        {
            "names": [
                "t",
                ":t"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_TERMINAL_PANE:-3} 2>/dev/null || tmux select-pane -t terminal 2>/dev/null",
            "description": "Focus Terminal",
            "category": "Navigation"
        },
        {
            "names": [
                "c",
                ":c"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_CHAT_PANE:-4} 2>/dev/null || tmux select-pane -t chat 2>/dev/null",
            "description": "Focus AI Chat",
            "category": "Navigation"
        },
        {
            "names": [
                "theme",
                ":theme"
            ],
            "action": "$NEXUS_BOOT/theme.sh menu",
            "description": "Change color theme",
            "category": "View"
        },
        {
            "names": [
                "a",
                "actions",
                ":a",
                ":actions"
            ],
            "action": "tmux send-keys -t ${PX_NEXUS_MENU_PANE:-menu} 'library' Enter && tmux select-pane -t ${PX_NEXUS_MENU_PANE:-menu}",
            "description": "Switch to Quick Actions",
            "category": "Menu"
        },
        {
            "names": [
                "help",
                ":help",
                "?",
                ":?"
            ],
            "action": "internal:help",
            "description": "Show this help menu",
            "category": "System"
        }
    ]
}