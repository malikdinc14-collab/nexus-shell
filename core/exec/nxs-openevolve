#!/bin/bash
# core/exec/nxs-openevolve
# Launcher for OpenEvolve evolutionary coding agent.

EXTERNAL_DIR="/Users/Shared/Projects/external_repos/openevolve"

if [[ ! -d "$EXTERNAL_DIR" ]]; then
    echo "Error: OpenEvolve repository not found at $EXTERNAL_DIR"
    exit 1
fi

cd "$EXTERNAL_DIR"

# Check for virtualenv
if [[ ! -d ".venv" ]]; then
    echo "[*] Initializing OpenEvolve Virtualenv..."
    python3 -m venv .venv
    source .venv/bin/activate
    pip install -e .
else
    source .venv/bin/activate
fi

echo "[Nexus] Launching OpenEvolve: Evolutionary Coding Agent"
python3 openevolve-run.py "$@"
