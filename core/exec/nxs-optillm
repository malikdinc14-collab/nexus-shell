#!/bin/bash
# core/exec/nxs-optillm
# Launcher for OptiLLM reasoning proxy.

EXTERNAL_DIR="/Users/Shared/Projects/external_repos/optillm"

if [[ ! -d "$EXTERNAL_DIR" ]]; then
    echo "Error: OptiLLM repository not found at $EXTERNAL_DIR"
    exit 1
fi

cd "$EXTERNAL_DIR"

# Check for virtualenv
if [[ ! -d ".venv" ]]; then
    echo "[*] Initializing OptiLLM Virtualenv..."
    python3 -m venv .venv
    source .venv/bin/activate
    pip install -r requirements.txt
else
    source .venv/bin/activate
fi

echo "[Nexus] Launching OptiLLM Inference Proxy..."
python3 -m optillm.optillm "$@"
