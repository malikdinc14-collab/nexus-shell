#!/bin/bash
# lib/git_hooks/post-checkout
# Triggered by Git immediately after a successful checkout.
# Orchestrates Nexus-Shell to swap workspace layouts.

OLD_REF="$1"
NEW_REF="$2"
CHECKOUT_TYPE="$3"

# Only proceed if this is a branch checkout (not a file checkout)
if [[ "$CHECKOUT_TYPE" != "1" ]]; then
    exit 0
fi

# Resolve branch names natively
NEW_BRANCH=$(git branch --show-current 2>/dev/null)
# @{-1} reliably gets the branch we just came from
OLD_BRANCH=$(git rev-parse --abbrev-ref @{-1} 2>/dev/null)

if [[ -z "$OLD_BRANCH" || -z "$NEW_BRANCH" || "$OLD_BRANCH" == "$NEW_BRANCH" ]]; then
    exit 0
fi

NEXUS_HOME="${NEXUS_HOME:-$HOME/.config/nexus-shell}"
if [[ -x "$NEXUS_HOME/core/exec/branch_sync.sh" ]]; then
    # Run the orchestrator in the background so it doesn't block the git command prompt
    "$NEXUS_HOME/core/exec/branch_sync.sh" "$OLD_BRANCH" "$NEW_BRANCH" &
    disown
fi
exit 0
