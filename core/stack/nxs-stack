# Paths
USER_TMP = Path(f"/tmp/nexus_{os.getlogin()}")
TRACE_DIR = USER_TMP / "trace"
TRACE_SESSION_FILE = TRACE_DIR / "active_session"
RESERVOIR = "RESERVOIR"

## Resource Limits
MAX_STACK_SIZE = int(os.environ.get("NEXUS_MAX_STACK", "20"))
GLOBAL_RESERVOIR_CAP = 80
ROLE_CAPS = {
    "menu": 1
}

def _get_reservoir_panes():
    """Returns a list of pane IDs currently in the reservoir."""
    res = run_tmux(["list-panes", "-t", f"{SESSION_ID}:{RESERVOIR}", "-F", "#{pane_id}"])
    return res.split("\n") if res else []

def _global_prune(state):
    """Ensures total panes in reservoir don't exceed GLOBAL_RESERVOIR_CAP."""
    res_panes = _get_reservoir_panes()
    if len(res_panes) <= GLOBAL_RESERVOIR_CAP: return
    
    log(f"Global Reservoir Cap Reached ({len(res_panes)} > {GLOBAL_RESERVOIR_CAP}). Pruning oldest background tabs.")
    
    # Identify all tabs that are currently in the reservoir
    candidates = []
    for role, data in state.items():
        for i, tab in enumerate(data["tabs"]):
            if i == 0: continue # Foundation is sacred
            if tab["id"] in res_panes:
                candidates.append((role, i, tab["id"]))
    
    # Prune oldest until we are under the cap (crude FIFO based on state order)
    # Future: use timestamps for better FIFO
    while len(res_panes) > GLOBAL_RESERVOIR_CAP and candidates:
        role, idx, pane_id = candidates.pop(0)
        log(f"Global Prune: Killing {pane_id} from role {role}")
        run_tmux(["kill-pane", "-t", pane_id])
        state[role]["tabs"].pop(idx)
        if state[role].get("active_index", 0) >= idx:
            state[role]["active_index"] -= 1
        res_panes = _get_reservoir_panes()

def _trace(event_type, **data):
    try:
        if not TRACE_SESSION_FILE.exists():
            return
        trace_path = Path(TRACE_SESSION_FILE.read_text().strip())
        if not trace_path.exists():
            return
        
        entry = {
            "ts": datetime.now().isoformat(timespec="milliseconds"),
            "type": event_type,
            **data
        }
        with open(trace_path, "a") as f:
            f.write(json.dumps(entry) + "\n")
    except:
        pass

def get_session_id():
    try: return subprocess.check_output(["tmux", "display-message", "-p", "#S"]).decode().strip()
    except: return None

SESSION_ID = get_session_id()

def log(msg):
    USER_TMP.mkdir(parents=True, exist_ok=True)
    with open(USER_TMP / "stack.log", "a") as f:
        f.write(f"[{SESSION_ID}] {msg}\n")

def run_tmux(args):
    import time
    start = time.time()
    try:
        result = subprocess.check_output(["tmux"] + args).decode().strip()
        duration = int((time.time() - start) * 1000)
        _trace("TMUX_CMD", args=args, result=result, duration_ms=duration)
        return result
    except Exception as e:
        log(f"Tmux Error: {args} -> {e}")
        _trace("TMUX_ERROR", args=args, error=str(e))
        return None

def ghost_swap(source_pane, target_pane):
    """Swaps panes while keeping the @nexus_slot anchored to the physical location."""
    if source_pane == target_pane: return True
    
    # 1. Detach: Capture physical slot from source
    slot = run_tmux(["display-message", "-p", "-t", source_pane, "#{@nexus_slot}"])
    
    _trace("GHOST_SWAP_START", source=source_pane, target=target_pane, slot=slot)
    
    # 2. Swap: The containers move
    # Use explicit window check to verify IDs still exist
    res = run_tmux(["swap-pane", "-d", "-s", source_pane, "-t", target_pane])
    if res is None:
        log(f"CRITICAL: swap-pane failed between {source_pane} and {target_pane}")
        return False

    # 3. Assign: Re-apply slot to the new occupant of the physical spot
    if slot and slot != "null":
        run_tmux(["set-option", "-p", "-t", target_pane, "@nexus_slot", slot])
        _trace("GHOST_SWAP_COMPLETE", target=target_pane, assigned_slot=slot)
    return True

def pane_exists(pane_id):
    if not pane_id: return False
    exists = run_tmux(["list-panes", "-a", "-F", "#{pane_id}"])
    if exists is None: return True 
    return pane_id in exists.split("\n")

# State Handshake
sys.path.append(str(Path(__file__).resolve().parent.parent / "state"))
