class ControlProxy:
    def __init__(self):
        self.bridge = ControlBridge() if ControlBridge else None
    
    def rotate_editor(self, direction):
        if not self.bridge: return False
        cmd = ":tabnext" if direction > 0 else ":tabprev"
        success, _ = self.bridge.send_to_editor(cmd)
        return success

