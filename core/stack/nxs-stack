except ImportError:
    NexusStateEngine = None

def get_engine():
    project_root = os.environ.get("PROJECT_ROOT", os.getcwd())
    if NexusStateEngine:
        return NexusStateEngine(project_root)
    return None

def load_state():
    engine = get_engine()
    if engine:
        return engine.get("ui.stacks") or {}
    return {}

def save_state(state):
    engine = get_engine()
    if engine:
        engine.set("ui.stacks", state)

def cleanup_reservoir():
    state = load_state()
    active_panes = run_tmux(["list-panes", "-a", "-F", "#{pane_id}"])
    if active_panes is None: return
    active_panes = active_panes.split("\n")
    
    dirty = False
    for role in list(state.keys()):
        tabs = state[role]["tabs"]
        # Rule: If Foundation is dead, the role is dead.
        if tabs[0]["id"] not in active_panes:
            log(f"Foundation for role {role} is dead. Purging entire role.")
            del state[role]
            dirty = True
            continue
            
        new_tabs = [t for t in tabs if t["id"] in active_panes]
        if len(new_tabs) != len(tabs):
            log(f"Pruning dead tools for {role}")
            state[role]["tabs"] = new_tabs
            if state[role]["active_index"] >= len(new_tabs):
                state[role]["active_index"] = 0
            dirty = True
            
    if dirty: save_state(state)

def _prune_stack(state, role):
    """Ensures stack doesn't exceed caps by removing oldest non-foundation tabs."""
    if role not in state: return
    tabs = state[role]["tabs"]
    
    limit = ROLE_CAPS.get(role, MAX_STACK_SIZE)
    if len(tabs) <= limit: return

    # Prune oldest non-foundation tab
    to_kill = tabs[1]["id"]
    log(f"Pruning {to_kill} for role {role} (Cap: {limit})")
    
    win_info = run_tmux(["display-message", "-p", "-t", to_kill, "#{window_name}"])
    if win_info != RESERVOIR:
        return

    run_tmux(["kill-pane", "-t", to_kill])
    state[role]["tabs"].pop(1)
    if state[role]["active_index"] >= 1:
        state[role]["active_index"] -= 1
    
    _global_prune(state)

def is_role_routing_enabled():
    return os.environ.get("NEXUS_ROLE_ROUTING", "true").lower() == "true"

def resolve_role(role):
    focused_id = run_tmux(["display-message", "-p", "#{pane_id}"])
    focused_role = run_tmux(["display-message", "-p", "-t", focused_id, "#{@nexus_role}"])
    focused_slot = run_tmux(["display-message", "-p", "-t", focused_id, "#{@nexus_slot}"])
    
    # "local" or None = resolve to either Current Slot Role or Slot ID
    if not role or role == "local":
        # Rule: Slot Identity is the ultimate invariant.
        # If we have a slot but role-routing is off, use slot_N as the role.
        if focused_slot and focused_slot != "null":
            slot_id = f"slot_{focused_slot}"
            # If we are in role-routing mode, and we have a named role, use it.
            # UNLESS the role starts with slot_ (meaning we already transitioned)
            if is_role_routing_enabled() and focused_role and not focused_role.startswith("slot_") and focused_role != "null":
                result = focused_role
            else:
                result = slot_id
        elif is_role_routing_enabled():
            result = focused_role if focused_role and focused_role != "null" else focused_id
        else:
            result = focused_id
        
        _trace("RESOLVE_ROLE", input=role, focused_id=focused_id, slot=focused_slot, role_on_focused=focused_role, output=result, role_routing=is_role_routing_enabled())
        return result
    
    _trace("RESOLVE_ROLE", input=role, focused_id=focused_id, role_on_focused=focused_role, output=role)
    return role

def ensure_reservoir():
    if not SESSION_ID: return False
    exists = run_tmux(["list-windows", "-t", SESSION_ID, "-F", "#{window_name}"])
    if not exists or RESERVOIR not in exists.split("\n"):
        run_tmux(["new-window", "-d", "-n", RESERVOIR, "-t", SESSION_ID])
        run_tmux(["set-option", "-p", "-t", f"{SESSION_ID}:{RESERVOIR}.0", "@nexus_role", "reservoir-root"])
    return True


def resolve_intent(intent_str):
    parts = intent_str.split(":", 2)
    return parts[2] if len(parts) == 3 else intent_str

def push(role, cmd, name=None):
    if not ensure_reservoir(): return
    if cmd.startswith("intent:"): cmd = resolve_intent(cmd)
    
    role = resolve_role(role)
    state = load_state()
    focused_id = run_tmux(["display-message", "-p", "#{pane_id}"])

    if role not in state:
        # Axiom: Foundation Isolation. 
        current_role = run_tmux(["display-message", "-p", "-t", focused_id, "#{@nexus_role}"])
        if current_role and current_role != role and current_role != "null":
            # Reservoir Discipline: Use split-window in Reservoir instead of new-window
            foundation_id = run_tmux(["split-window", "-d", "-t", f"{SESSION_ID}:{RESERVOIR}", "-P", "-F", "#{pane_id}", "-c", os.getcwd(), "zsh"])
            state[role] = {"active_index": 0, "tabs": [{"id": foundation_id, "name": "nexus-terminal"}]}
            run_tmux(["set-option", "-p", "-t", foundation_id, "@nexus_role", role])
        else:
            state[role] = {"active_index": 0, "tabs": [{"id": focused_id, "name": "nexus-terminal"}]}
            run_tmux(["set-option", "-p", "-t", focused_id, "@nexus_role", role])

    # Immortal Wrapper: Ensure tool exit returns to terminal (index 0)
    nexus_home = os.environ.get("NEXUS_HOME", str(Path(__file__).resolve().parent.parent.parent))
    wrapped_cmd = f"zsh -c '{cmd}; {nexus_home}/core/stack/nxs-stack switch local 0'"
    
    # Reservoir Discipline: Background tool spawn
    new_pane_id = run_tmux(["split-window", "-d", "-t", f"{SESSION_ID}:{RESERVOIR}", "-P", "-F", "#{pane_id}", "-c", os.getcwd(), wrapped_cmd])
    if not new_pane_id: return

    tab_name = name or (Path(cmd.split()[-1]).name if "/" in cmd else "Shell")
    run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_role", role])
    run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_tab_name", tab_name])

    focused_in_tabs = any(t["id"] == focused_id for t in state[role]["tabs"])
    visible_pane = focused_id if focused_in_tabs else None
    reason = "focused pane in tabs" if focused_in_tabs else None
    
    if not visible_pane:
        for tab in state[role]["tabs"]:
            win_info = run_tmux(["display-message", "-p", "-t", tab["id"], "#{window_name}"])
            if win_info and win_info != RESERVOIR:
                visible_pane = tab["id"]
                reason = f"first visible in window (tab {tab['id']})"
                break
    
    if not visible_pane:
        visible_pane = focused_id
        reason = "fallback to focused"
    
    _trace("RESOLVE_VISIBLE", focused_id=focused_id, tabs=[{"id": t.get("id"), "name": t.get("name")} for t in state[role]["tabs"]], result=visible_pane, reason=reason)
    _trace("STACK_PUSH", role=role, cmd=cmd, name=tab_name, visible=visible_pane, new_pane=new_pane_id)
    
    if ghost_swap(visible_pane, new_pane_id):
        run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_portal_return", ""])
        run_tmux(["select-pane", "-t", new_pane_id])
    else:
        log(f"Push Swap Failed: {new_pane_id} remains in reservoir.")
    
    state[role]["tabs"].append({"id": new_pane_id, "name": tab_name})
    state[role]["active_index"] = len(state[role]["tabs"]) - 1
    _prune_stack(state, role)
    save_state(state)

def switch_to(role, index):
    ensure_reservoir()
    role = resolve_role(role)
    state = load_state()
    focused_id = run_tmux(["display-message", "-p", "#{pane_id}"])

    try: index = int(index)
    except: return

    if role not in state or index >= len(state[role]["tabs"]): return
    new_pane_id = state[role]["tabs"][index]["id"]

    if not pane_exists(new_pane_id):
        cleanup_reservoir()
        return switch_to(role, 0) if role in state else None

    focused_in_tabs = any(t["id"] == focused_id for t in state[role]["tabs"])
    visible_pane = focused_id if focused_in_tabs else None
    reason = "focused pane in tabs" if focused_in_tabs else None
    
    if not visible_pane:
        for tab in state[role]["tabs"]:
            win_info = run_tmux(["display-message", "-p", "-t", tab["id"], "#{window_name}"])
            if win_info and win_info != RESERVOIR:
                visible_pane = tab["id"]
                reason = f"first visible in window (tab {tab['id']})"
                break
    
    if not visible_pane:
        visible_pane = focused_id
        reason = "fallback to focused"
    
    _trace("RESOLVE_VISIBLE", focused_id=focused_id, tabs=[{"id": t.get("id"), "name": t.get("name")} for t in state[role]["tabs"]], result=visible_pane, reason=reason)
    _trace("STACK_SWITCH", role=role, index=index, from_pane=visible_pane, to_pane=new_pane_id)

    if visible_pane != new_pane_id:
        if ghost_swap(visible_pane, new_pane_id):
            run_tmux(["select-pane", "-t", new_pane_id])
            state[role]["active_index"] = index
            _global_prune(state)
            save_state(state)
        else:
            log(f"Switch Swap Failed: {new_pane_id} remains in reservoir.")

def rotate(role, direction):
    role = resolve_role(role)
    state = load_state()
    focused_id = run_tmux(["display-message", "-p", "#{pane_id}"])
    current_cmd = run_tmux(["display-message", "-p", "-t", focused_id, "#{pane_current_command}"])
    
    if (role == "editor" or (current_cmd and "nvim" in current_cmd)):
        if BRIDGE.rotate_editor(direction):
            return

    if role not in state: return
    count = len(state[role]["tabs"])
    new_idx = (state[role]["active_index"] + direction) % count
    switch_to(role, new_idx)

def close_tab(role):
    role = resolve_role(role)
    state = load_state()
    focused_id = run_tmux(["display-message", "-p", "#{pane_id}"])

    if role not in state or not state[role]["tabs"]:
        run_tmux(["kill-pane", "-t", focused_id])
        return
    
    idx = state[role]["active_index"]
    tabs = state[role]["tabs"]

    if idx == 0:
        log(f"Foundation kill: {role}")
        run_tmux(["kill-pane", "-t", focused_id])
        del state[role]
        save_state(state)
    else:
        pane_to_kill = tabs[idx]["id"]
        # Find visible pane to swap away from
        visible_pane = focused_id if any(t["id"] == focused_id for t in tabs) else None
        if not visible_pane:
            for tab in tabs:
                win_info = run_tmux(["display-message", "-p", "-t", tab["id"], "#{window_name}"])
                if win_info and win_info != RESERVOIR:
                    visible_pane = tab["id"]
                    break

        # Determine next active
        next_idx = (idx + 1) % len(tabs)
        if next_idx == idx: next_idx = 0
        new_active_pane = tabs[next_idx]["id"]

        if ghost_swap(visible_pane, new_active_pane):
            run_tmux(["select-pane", "-t", new_active_pane])
            run_tmux(["kill-pane", "-t", visible_pane])
        else:
            log(f"Close Tab Swap Failed: {visible_pane} was not swapped.")
        
        new_tabs = [t for t in tabs if t["id"] != pane_to_kill]
        state[role]["tabs"] = new_tabs
        for i, t in enumerate(new_tabs):
            if t["id"] == new_active_pane:
                state[role]["active_index"] = i
                break
        save_state(state)

def replace(role, cmd, name=None):
    if not ensure_reservoir(): return
    if cmd.startswith("intent:"): cmd = resolve_intent(cmd)
    
    role = resolve_role(role)
    state = load_state()
    focused_id = run_tmux(["display-message", "-p", "#{pane_id}"])
    
    # Immortal Wrapper: Fallback to terminal
    nexus_home = os.environ.get("NEXUS_HOME", str(Path(__file__).resolve().parent.parent.parent))
    wrapped_cmd = f"zsh -c '{cmd}; {nexus_home}/core/stack/nxs-stack switch local 0'"

    # Reservoir Discipline: Replace operation spawn
    new_pane_id = run_tmux(["split-window", "-d", "-t", f"{SESSION_ID}:{RESERVOIR}", "-P", "-F", "#{pane_id}", "-c", os.getcwd(), wrapped_cmd])
    if not new_pane_id: return

    tab_name = name or (Path(cmd.split()[-1]).name if "/" in cmd else "Shell")
    run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_role", role])
    run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_tab_name", tab_name])

    visible_pane = None
    reason = None
    if role in state:
        focused_in_tabs = any(t["id"] == focused_id for t in state[role]["tabs"])
        visible_pane = focused_id if focused_in_tabs else None
        reason = "focused pane in tabs" if focused_in_tabs else None
        if not visible_pane:
            for tab in state[role]["tabs"]:
                win_info = run_tmux(["display-message", "-p", "-t", tab["id"], "#{window_name}"])
                if win_info and win_info != RESERVOIR:
                    visible_pane = tab["id"]
                    reason = f"first visible in window (tab {tab['id']})"
                    break
    if not visible_pane: 
        visible_pane = focused_id
        reason = "fallback to focused"
    
    _trace("RESOLVE_VISIBLE", focused_id=focused_id, tabs=[{"id": t.get("id"), "name": t.get("name")} for t in state.get(role, {}).get("tabs", [])], result=visible_pane, reason=reason)
    _trace("STACK_REPLACE", role=role, cmd=cmd, name=tab_name, visible=visible_pane, new_pane=new_pane_id)
    _trace("SWAP_EXEC", source=visible_pane, target=new_pane_id)

    if role in state:
        idx = state[role]["active_index"]
        target_to_replace = state[role]["tabs"][idx]["id"]
        if idx == 0:
            log("Foundation Protection: Upgrading Replace to Push.")
            if ghost_swap(visible_pane, new_pane_id):
                run_tmux(["select-pane", "-t", new_pane_id])
                state[role]["tabs"].append({"id": new_pane_id, "name": tab_name})
                state[role]["active_index"] = len(state[role]["tabs"]) - 1
        else:
            if ghost_swap(visible_pane, new_pane_id):
                run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_role", role])
                run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_portal_return", ""])
                run_tmux(["select-pane", "-t", new_pane_id])
                if target_to_replace != new_pane_id: run_tmux(["kill-pane", "-t", target_to_replace])
                state[role]["tabs"][idx] = {"id": new_pane_id, "name": tab_name}
            else:
                log(f"Replace Swap Failed: {new_pane_id} remains in reservoir.")
    else:
        # Migration: Replace current pane with a tool from a new role
        current_role = run_tmux(["display-message", "-p", "-t", focused_id, "#{@nexus_role}"])
        if current_role and current_role != role and current_role != "null":
            # Reservoir Discipline for Foundations
            foundation_id = run_tmux(["split-window", "-d", "-t", f"{SESSION_ID}:{RESERVOIR}", "-P", "-F", "#{pane_id}", "-c", os.getcwd(), "zsh"])
            state[role] = {"active_index": 1, "tabs": [{"id": foundation_id, "name": "nexus-terminal"}, {"id": new_pane_id, "name": tab_name}]}
            run_tmux(["set-option", "-p", "-t", foundation_id, "@nexus_role", role])
        else:
            state[role] = {"active_index": 1, "tabs": [{"id": focused_id, "name": "nexus-terminal"}, {"id": new_pane_id, "name": tab_name}]}
        
        if ghost_swap(visible_pane, new_pane_id):
            run_tmux(["set-option", "-p", "-t", new_pane_id, "@nexus_portal_return", ""])
            run_tmux(["select-pane", "-t", new_pane_id])
        else:
            log(f"Migration Swap Failed: {new_pane_id} remains in reservoir.")
    
    _prune_stack(state, role)
    save_state(state)
    cleanup_reservoir()

def list_tabs(role):
    role = resolve_role(role)
    state = load_state()
    if role in state: print(json.dumps(state[role]))

if __name__ == "__main__":
    if len(sys.argv) < 2: sys.exit(1)
    action = sys.argv[1]
    if action == "init": ensure_reservoir()
    elif action == "push" and len(sys.argv) >= 4:
        push(sys.argv[2], sys.argv[3], sys.argv[4] if len(sys.argv) > 4 else None)
    elif action == "replace" and len(sys.argv) >= 4:
        replace(sys.argv[2], sys.argv[3], sys.argv[4] if len(sys.argv) > 4 else None)
    elif action in ["switch", "switch_to"] and len(sys.argv) >= 4:
        switch_to(sys.argv[2], sys.argv[3])
    elif action == "next" and len(sys.argv) >= 3:
        rotate(sys.argv[2], 1)
    elif action == "prev" and len(sys.argv) >= 3:
        rotate(sys.argv[2], -1)
    elif action in ["close", "close_tab", "pop"] and len(sys.argv) >= 3:
        close_tab(sys.argv[2])
    elif action == "list" and len(sys.argv) >= 3:
        list_tabs(sys.argv[2])
