#!/usr/bin/env bash
# core/stack/nxs-stack-popup
# Triggered when nxs-stack cannot find a suitable slot to swap.

ROLE="$1"
CMD="$2"

echo "[!] Nexus Stack: No active slot found for '$ROLE'."
echo "What should we do?"
echo "1) Split current pane and create slot"
echo "2) Hot-swap current focused pane"
echo "3) Abort"

read -p "Choice [1-3]: " choice

case $choice in
    1)
        # Split and tag
        tmux split-window -v -p 30 -c "$(pwd)" "$CMD"
        NEW_PANE=$(tmux display-message -p '#{pane_id}')
        tmux set-option -p -t "$NEW_PANE" @nexus_role "$ROLE"
        ;;
    2)
        # Force swap
        visible_pane=$(tmux display-message -p '#{pane_id}')
        /Users/Shared/Projects/nexus-shell/core/stack/nxs-stack push_force "$ROLE" "$CMD" "$visible_pane"
        ;;
    *)
        echo "Aborted."
        exit 0
        ;;
esac
