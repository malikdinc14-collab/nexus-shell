#!/bin/bash
# core/exec/nxs-optillm
# Launcher for OptiLLM reasoning proxy.

# 0. Resolve Paths
export PI_MONO_ROOT="$NEXUS_HOME/external/pi-mono"
export OPTILLM_ROOT="$NEXUS_HOME/external/optillm"
VENV_PATH="$OPTILLM_ROOT/venv"

if [[ ! -d "$OPTILLM_ROOT" ]]; then
    echo "Error: OptiLLM repository not found at $OPTILLM_ROOT"
    exit 1
fi

cd "$OPTILLM_ROOT"

# Check for virtualenv
if [[ ! -d ".venv" ]]; then
    echo "[*] Initializing OptiLLM Virtualenv..."
    python3 -m venv .venv
    source .venv/bin/activate
    pip install -r requirements.txt
else
    source .venv/bin/activate
fi

echo "[Nexus] Launching OptiLLM Inference Proxy..."
python3 -m optillm.optillm "$@"
