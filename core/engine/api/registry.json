{
    "commands": [
        {
            "names": [
                "build",
                ":b"
            ],
            "action": "$NEXUS_KERNEL/exec/stack_manager.sh build",
            "description": "Show project build actions",
            "category": "System"
        },
        {
            "names": [
                "actions"
            ],
            "action": "$NEXUS_KERNEL/exec/stack_manager.sh actions",
            "description": "Show project-specific actions",
            "category": "System"
        },
        {
            "names": [
                "beacon"
            ],
            "action": "$NEXUS_SERVICES/beacon_overlay.sh &",
            "description": "Start the Sovereign Beacon HUD pulse",
            "category": "System"
        },
        {
            "names": [
                "profiles",
                ":p"
            ],
            "action": "$NEXUS_ENGINE/env/list_profiles.sh",
            "description": "List available profiles",
            "category": "System"
        },
        {
            "names": [
                "q",
                ":q"
            ],
            "action": "$NEXUS_BOOT/guard.sh exit_session",
            "description": "Quit Station",
            "category": "Exit"
        },
        {
            "names": [
                "qa",
                ":qa"
            ],
            "action": "$NEXUS_BOOT/guard.sh exit_session",
            "description": "Quit entire session (all windows)",
            "category": "Exit"
        },
        {
            "names": [
                "wq",
                ":wq"
            ],
            "action": "python3 $NEXUS_KERNEL/layout/save_layout.py && sleep 0.8 && $NEXUS_BOOT/guard.sh exit_session",
            "description": "Freeze session and quit station",
            "category": "Exit",
            "preflight": "save_all"
        },
        {
            "names": [
                "wqa",
                ":wqa"
            ],
            "action": "python3 $NEXUS_KERNEL/layout/save_layout.py --all 2>/dev/null; sleep 0.8; $NEXUS_BOOT/guard.sh exit_session",
            "description": "Save all layouts and quit entire session",
            "category": "Exit",
            "preflight": "save_all"
        },
        {
            "names": [
                "save",
                ":save"
            ],
            "action": "python3 $NEXUS_KERNEL/layout/save_layout.py --export",
            "description": "Capture current window geometry and export to .nexus/compositions/<name>.json",
            "category": "System"
        },
        {
            "names": [
                "q!",
                ":q!"
            ],
            "action": "$NEXUS_BOOT/guard.sh force_session",
            "description": "Force quit station without saving",
            "category": "Exit"
        },
        {
            "names": [
                "qa!",
                ":qa!"
            ],
            "action": "$NEXUS_BOOT/guard.sh force_session",
            "description": "Force quit entire session without saving",
            "category": "Exit"
        },
        {
            "names": [
                "v",
                ":v"
            ],
            "action": "$NEXUS_ENGINE/lib/swap.sh",
            "description": "Toggle Editor/Render mode",
            "category": "View"
        },
        {
            "names": [
                "g",
                ":g"
            ],
            "action": "$NEXUS_ENGINE/lib/tree_swap.sh",
            "description": "Toggle Tree/Git mode",
            "category": "View"
        },
        {
            "names": [
                "kill",
                ":kill"
            ],
            "action": "$NEXUS_ENGINE/api/kill_agent.sh",
            "description": "Terminate active agent loops",
            "category": "AI"
        },
        {
            "names": [
                "down",
                ":down"
            ],
            "action": "$NEXUS_ENGINE/api/unload_brains.sh",
            "description": "Unload all local models and backends",
            "category": "AI"
        },
        {
            "names": [
                "spawn",
                ":spawn"
            ],
            "action": "$NEXUS_BIN/px-window-spawn",
            "description": "Open a new terminal tab (spawn 2 for Monitor)",
            "category": "System",
            "args": true
        },
        {
            "names": [
                "n",
                ":n"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_TREE_PANE:-0} 2>/dev/null || tmux select-pane -t tree 2>/dev/null",
            "description": "Focus Navigator (Tree)",
            "category": "Navigation"
        },
        {
            "names": [
                "p",
                ":p",
                "px",
                "parallax",
                ":px",
                ":parallax"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_PARALLAX_PANE:-1} 2>/dev/null || tmux select-pane -t parallax 2>/dev/null",
            "description": "Focus Parallax Dashboard",
            "category": "Navigation"
        },
        {
            "names": [
                "e",
                ":e"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_EDITOR_PANE:-2} 2>/dev/null || tmux select-pane -t editor 2>/dev/null",
            "description": "Focus Editor",
            "category": "Navigation"
        },
        {
            "names": [
                "t",
                ":t"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_TERMINAL_PANE:-3} 2>/dev/null || tmux select-pane -t terminal 2>/dev/null",
            "description": "Focus Terminal",
            "category": "Navigation"
        },
        {
            "names": [
                "c",
                ":c"
            ],
            "action": "tmux select-pane -t ${PX_NEXUS_CHAT_PANE:-4} 2>/dev/null || tmux select-pane -t chat 2>/dev/null",
            "description": "Focus AI Chat",
            "category": "Navigation"
        },
        {
            "names": [
                "theme",
                ":theme"
            ],
            "action": "$NEXUS_BOOT/theme.sh menu",
            "description": "Change color theme",
            "category": "View"
        },
        {
            "names": [
                "a",
                "actions",
                ":a",
                ":actions"
            ],
            "action": "tmux send-keys -t ${PX_NEXUS_MENU_PANE:-menu} 'library' Enter && tmux select-pane -t ${PX_NEXUS_MENU_PANE:-menu}",
            "description": "Switch to Quick Actions",
            "category": "Menu"
        },
        {
            "names": [
                "help",
                ":help",
                "?",
                ":?"
            ],
            "action": "internal:help",
            "description": "Show this help menu",
