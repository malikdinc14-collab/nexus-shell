#!/bin/bash
# Nexus Event Bus CLI Client
# Publish and subscribe to events

set -e

# Get socket path
USER="${USER:-$(whoami)}"
PROJECT="${NEXUS_PROJECT:-default}"
SOCKET="/tmp/nexus_${USER}/${PROJECT}/bus.sock"

# Check if event bus is running
check_bus() {
    if [[ ! -S "$SOCKET" ]]; then
        echo "[event] Error: Event bus not running (socket not found: $SOCKET)" >&2
        return 1
    fi
}

# Publish event
nxs_event_publish() {
    local type="$1"
    local data="$2"
    
    if [[ -z "$type" ]]; then
        echo "Usage: event publish <type> <json_data>" >&2
        return 1
    fi
    
    if [[ -z "$data" ]]; then
        data="{}"
    fi
    
    check_bus || return 1
    
    local message=$(cat <<EOF
{"action": "publish", "type": "$type", "source": "${TMUX_PANE:-unknown}", "timestamp": $(date +%s.%N), "data": $data}
EOF
)
    
    # Use printf to send as single line
    printf "%s\n" "$message" | nc -U "$SOCKET" -w 1 2>/dev/null || {
        echo "[event] Error: Failed to publish event" >&2
        return 1
    }
}

# Subscribe to events
nxs_event_subscribe() {
    local type="$1"
    local handler="$2"
    
    if [[ -z "$type" ]]; then
        echo "Usage: event subscribe <type> [handler]" >&2
        return 1
    fi
    
    check_bus || return 1
    
    local message='{"action": "subscribe", "type": "'$type'"}'
    
    # Send subscription request and read events
    {
        printf "%s\n" "$message"
        
        # If handler provided, pipe events to it
        if [[ -n "$handler" ]]; then
            while read -r event; do
                # Skip confirmation message
                if echo "$event" | jq -e '.status == "subscribed"' >/dev/null 2>&1; then
                    echo "[event] Subscribed to $type" >&2
                    continue
                fi
                
                # Pass event to handler
                if [[ "$handler" == "-" ]]; then
                    echo "$event"
                else
                    echo "$event" | "$handler"
                fi
            done
        else
            # Just print events
            while read -r event; do
                if echo "$event" | jq -e '.status == "subscribed"' >/dev/null 2>&1; then
                    echo "[event] Subscribed to $type" >&2
                    continue
                fi
                echo "$event" | jq '.'
            done
        fi
    } | nc -U "$SOCKET" 2>/dev/null
}

# List subscriptions
nxs_event_list() {
    check_bus || return 1
    
    local message='{"action": "list"}'
    
    printf "%s\n" "$message" | nc -U "$SOCKET" -w 1 2>/dev/null | jq -r '
        if .status == "ok" then
            "Event Subscriptions:",
            (.subscriptions | to_entries[] | "  \(.key): \(.value) subscriber(s)")
        else
            "Error: \(.error)"
        end
    '
}

# Get event history
nxs_event_history() {
    local type="$1"
    local limit="${2:-10}"
    
    check_bus || return 1
    
    local message='{"action": "history", "type": "'$type'", "limit": '$limit'}'
    
    printf "%s\n" "$message" | nc -U "$SOCKET" -w 1 2>/dev/null | jq -r '
        if .status == "ok" then
            "Event History (\(.count) events):",
            (.events[] | "[\(.timestamp | tonumber | strftime("%H:%M:%S"))] \(.type): \(.data)")
        else
            "Error: \(.error)"
        end
    '
}

# Show usage
usage() {
    cat <<EOF
Nexus Event Bus CLI

Usage:
  event publish <type> <json_data>    Publish an event
  event subscribe <type> [handler]    Subscribe to events
  event list                          List active subscriptions
  event history [type] [limit]        Show event history

Examples:
  # Publish a file saved event
  event publish FS_EVENT '{"action":"file_saved","path":"main.py"}'
  
  # Subscribe and print events
  event subscribe FS_EVENT
  
  # Subscribe with handler script
  event subscribe TEST_EVENT ./my_handler.sh
  
  # List subscriptions
  event list
  
  # Show last 20 FS_EVENT events
  event history FS_EVENT 20

Event Types:
  FS_EVENT      - File system events (open, save, close)
  TEST_EVENT    - Test execution events (pass, fail, running)
  EDITOR_EVENT  - Editor events (cursor, selection, buffer)
  AI_EVENT      - AI chat events (response, error)
  GAP_EVENT     - GAP workflow events (gate, ACL, validation)
  UI_EVENT      - UI events (focus, resize, crash)
EOF
}

# Main command router
case "$1" in
    publish)
        shift
        nxs_event_publish "$@"
        ;;
    subscribe|sub)
        shift
        nxs_event_subscribe "$@"
        ;;
    list|ls)
        nxs_event_list
        ;;
    history|hist)
        shift
        nxs_event_history "$@"
        ;;
    help|--help|-h)
        usage
        ;;
    *)
        echo "Error: Unknown command '$1'" >&2
        echo "Run 'event help' for usage" >&2
        exit 1
        ;;
esac
