{
    "name": "vscodelike",
    "description": "A feature-rich layout mimicking modern IDEs with tree, editor, terminal, and AI chat.",
    "layout": {
        "type": "hsplit",
        "panes": [
            {
                "id": "files",
                "size": 30,
                "command": "$NEXUS_FILES '$PROJECT_ROOT'"
            },
            {
                "type": "vsplit",
                "panes": [
                    {
                        "id": "parallax",
                        "size": 8,
                        "command": "$PARALLAX_CMD"
                    },
                    {
                        "id": "editor",
                        "command": "$EDITOR_CMD"
                    },
                    {
                        "type": "hsplit",
                        "size": 12,
                        "panes": [
                            {
                                "id": "terminal",
                                "command": "/bin/zsh -i"
                            },
                            {
                                "id": "trace",
                                "size": 35,
                                "command": "tail -f /tmp/px-agent-trace.log"
                            }
                        ]
                    }
                ]
            },
            {
                "type": "vsplit",
                "size": 45,
                "panes": [
                    {
                        "id": "chat",
                        "command": "gptme"
                    },
                    {
                        "id": "ui",
                        "size": 5,
                        "command": "/bin/zsh -i"
                    }
                ]
            }
        ]
    }
}