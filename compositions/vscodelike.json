{
    "name": "vscodelike",
    "description": "A feature-rich layout mimicking modern IDEs with tree, editor, terminal, and AI chat.",
    "layout": {
        "type": "hsplit",
        "panes": [
            {
                "id": "files",
                "size": 30,
                "command": "YAZI_CONFIG_HOME=\"$NEXUS_HOME/config/yazi\" $NEXUS_FILES '$PROJECT_ROOT'"
            },
            {
                "type": "vsplit",
                "panes": [
                    {
                        "id": "parallax",
                        "size": 8,
                        "command": "$PARALLAX_CMD"
                    },
                    {
                        "id": "editor",
                        "command": "$EDITOR_CMD"
                    },
                    {
                        "id": "terminal",
                        "size": 12,
                        "command": "/bin/zsh -i"
                    }
                ]
            },
            {
                "id": "chat",
                "size": 45,
                "command": "$NEXUS_CHAT"
            }
        ]
    }
}