{
    "name": "minimal",
    "description": "Minimal: just an editor and a terminal. Nothing else.",
    "layout": {
        "type": "vsplit",
        "panes": [
            {
                "id": "editor",
                "size": 70,
                "command": "$EDITOR_CMD"
            },
            {
                "id": "terminal",
                "command": "/bin/zsh -i"
            }
        ]
    }
}